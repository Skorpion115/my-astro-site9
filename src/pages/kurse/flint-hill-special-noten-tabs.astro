---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Flint Hill Special – Tabulatur + Mastering mp3 + Backing Track kaufen";
const heading = "Flint Hill Special - Tabulaturen kaufen";
const description =
  "Kaufe die Noten & Tabulaturen für ‚Flint Hill Special‘ direkt hier. Nach der Zahlung erhältst du Zugriff auf die Downloads.";
const keywords = "Flint Hill Special, Noten & Tabulaturen, 5-string Banjo, PDF";
const pageUrl = getPageUrl(Astro);
const returnUrl =
  "https://www.musicstudio-ziebart.de/kurse/thanks-flint-hill-special/";

const imageSrc = "/bilder/Flint_Hill_Special_Vorschau.png";
const imageAlt = "Flint Hill Special – Vorschau";
const price = "5,95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/flint_hill_special_preview.png";

const contentHtml = `

  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/1wm1MNi3-C03_88A45089bjo136fyS1wL/preview"
    width="60%"
    height="50"
  ></iframe>

  <p>
  <a
    href="https://www.youtube.com/watch?v=R75ZetEwmtw"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Flint Hill Special ansehen"
    rel="noopener"
  >
    ▶️ Flint Hill Special – Banjo Tutorial auf YouTube ansehen
  </a>
  </p>

  <p>
    Nach der Zahlung erhältst du sofortigen Zugriff auf die PDF Downloads. <br />
    Perfekt für 5-string Banjo-Spieler, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten- &amp; Tabulaturblätter zum Song „Flint Hill Special“</strong> – speziell erstellt für den Unterricht und das Selbststudium.
  </p>
  <ul>
    <li>5-string Banjo-Noten</li>
    <li>Audioaufnahme mp3</li>
    <li>Backing Track</li>
  </ul>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach der erfolgreichen PayPal-Zahlung erhältst du sofort Zugriff auf die Downloads.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF und MP3 zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
  ogImage={ogImage}
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
  />
</BaseLayout>