---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../../utils/getPageUrl.js";

const pageTitle = "Keyboard Lernmodule";
const description =
  "Lerne Gitarre mit strukturierten Lernmodulen: Strumming, Fingerstyle, Country und Blues – nach Stil und Level sortiert.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="website"
>
  <p>
    Hier findest du Keyboard-Stücke und Übungen im Stil von Jazz, Pop und Easy
    Listening. Schwerpunkt: Begleitpatterns, Melodie-Spiel und typische Sounds
    wie Hammond und Orgel.
  </p>

  <!-- 🔷 Lernwege / Kategorien -->
  <h2>Rubriken</h2>

  <div class="card-grid">
    <div class="basis-card">
      <h2>Hammond Orgel Klassiker</h2>

      <p>Begleitung und Melodie-Spiel im Stil von Klaus Wunderlich.</p>

      <ul>
        <li>
          <a href="/arrangements/hammond-flip/">
            Hammond Flip – Klaus Wunderlich
          </a>
        </li>
        <li>
          <a href="/arrangements/lullaby-in-blue/">
            Lullaby In Blue – Klaus Wunderlich
          </a>
        </li>
        <li>
          <a href="/arrangements/kleiner-schelm/">
            Kleiner Schelm – Klaus Wunderlich
          </a>
        </li>
        <li>
          <a href="/arrangements/des-interesse/">
            Des - interesse – Klaus Wunderlich
          </a>
        </li>
        <li>
          <a href="/arrangements/e-hering/">
            E - hering – Klaus Wunderlich
          </a>
        </li>
        <li>
          <a href="/arrangements/h-schisch/">
            H - schisch – Klaus Wunderlich
          </a>
        </li>
        <li>
          <a href="/arrangements/intermezzo/">
            Intermezzo – Rudi Ziebart
          </a>
        </li>
      </ul>
    </div>

    <div class="basis-card">
      <h3>Jazz Organ</h3>

      <p>
        Typischer Stil für die linke Hand von Harry Stoneham für Organisten oder
        Keyboardspieler.
      </p>

      <ul>
        <li>
          <a href="/arrangements/in-the-still-of-the-night/">
            In The Still Of The Night – Harry Stoneham
          </a>
        </li>
      </ul>
    </div>
  </div>

  <!-- 🔷 Optional: Erklärung -->
  <h2>Wie funktioniert das Lernen?</h2>

  <ul>
    <li>Du wählst einen Stil (z. B. Hammond Orgel Klassiker)</li>
    <li>Du lernst anhand eines konkreten Arrangements</li>
    <li>Du arbeitest mit echten Songs im Stil – ohne komplizierte Theorie</li>
  </ul>
</BaseLayout>
