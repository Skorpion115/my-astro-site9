---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Stairway To Heaven - Led Zeppelin Gitarren Noten & Tabs";
const heading = "Stairway To Heaven - Led Zeppelin Gitarren Noten & TABs";
const description = "Kaufe die Noten & Tabulaturen für ‚Stairway To Heaven‘ direkt hier. Nach der Zahlung erhältst du Zugriff auf die Downloads.";
const keywords = "Stairway To Heaven, Noten & Tabulaturen, Gitarre, PDF";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/kurse/thanks-stairway-to-heaven-led-zeppelin/";
const price = "8.95";
const contentHtml = `
  <br />
  <img
    src="/bilder/stairway_to_heaven_led_zeppelin_vorschau.png"
    alt="Stairway To Heaven Led Zeppelin Noten Vorschau"
    class="vorschau-image"
  />
  <p>
  <a
    href="https://www.youtube.com/watch?v=QkF3oxziUI4"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Stairway To Heaven ansehen"
    rel="noopener"
  >
    ▶️ Stairway To Heaven – Led Zeppelin auf YouTube ansehen
  </a>
  </p>

  <p><strong>Digitales Produkt (PDF Download)</strong></p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Gitarren Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>
    Perfekt für Gitarristen, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten- &amp; Tabulaturblätter zum Song „Stairway To Heaven“</strong>.
  </p>
  <p>
    Gitarren-Noten mit Akkorden und TABs + komplettes Arrangement als PDF-Download.
  </p>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach dem Kauf steht der Download sofort zur Verfügung.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF und MP3 zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>
  <p>
    <a href="/kurse/alle-kurse/#e-gitarren-kurse" class="cta-button">
      Weitere E-Gitarrensolos entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    price={price}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
  />
</BaseLayout>