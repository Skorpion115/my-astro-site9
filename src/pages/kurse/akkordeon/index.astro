---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../../utils/getPageUrl.js";

const pageTitle = "Akkordeon Lernmodule";
const description = "Lerne Akkordeon spielen.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="website"
>

  <p>
    Hier findest du die schönsten Akkordeon-Stücke.
  </p>

  <!-- 🔷 Lernwege / Kategorien -->
  <h2>Rubriken</h2>

  <div class="card-grid">

    <div class="basis-card">
      <h2>Musette Walzer</h2>

      <p>
        Melodie-Spiel im Stil von Sergio Castelli.
      </p>

      <ul>
        <li>
          <a href="/arrangements/akkordeon-triste/">
            L'accordéon triste – Sergio Castelli
          </a>
        </li>
      </ul>
    </div>
    

    <!--
    <div class="basis-card">
      <h3>Jazz Organ</h3>

      <p>Typischer Stil für die linke Hand von Harry Stoneham für Organisten oder Keyboardspieler.</p>

      <ul>
        <li>
          <a href="/arrangements/in-the-still-of-the-night/">
            In The Still Of The Night – Harry Stoneham
          </a>
        </li>
      </ul>
    </div> -->

  </div>

  <!-- 🔷 Optional: Erklärung -->
  <h2>Wie funktioniert das Lernen?</h2>

  <ul>
    <li>Du wählst einen Stil (z. B. Musette Walzer)</li>
    <li>Du lernst anhand eines konkreten Arrangements</li>
    <li>Du arbeitest mit echten Songs – ohne komplizierte Theorie</li>
  </ul>

</BaseLayout>