---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Catch The Wind – Noten & Tabulatur + Bassnoten + Mundharmonika Solo kaufen";
const description =
  "Kaufe die Noten & Tabulatur für ‚Catch The Wind‘ direkt hier. Nach der Zahlung erhältst du Zugriff auf die Downloads.";
const keywords = "Catch The Wind Noten, Catch The Wind Tabulatur, Gitarrennoten PDF, Donovan Catch The Wind";
const pageUrl = getPageUrl(Astro);
const returnUrl =
  "https://www.musicstudio-ziebart.de/kurse/thanks-catch-the-wind/";
const imageSrc = "/bilder/CatchTheWind_Vorschau.jpg";
const imageAlt = "Catch The Wind – Vorschau";
const price = "5.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/catch_the_wind_preview.png";

const contentHtml = `
  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/19jXw9-t0b-TLr_2xsYvPAVHdw5exWBzW/preview"
    width="60%"
    height="50"
  ></iframe>

  <p>
  <a
    href="https://www.youtube.com/watch?v=ifJuoPeWBU8"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Catch The Wind ansehen"
    rel="noopener"
  >
    ▶️ Catch The Wind – Gitarre Tutorial auf YouTube ansehen
  </a>
  </p>
  <p>
    Nach der Zahlung erhältst du sofortigen Zugriff auf die PDF Downloads. <br />
    Perfekt für Gitarristen, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten- &amp; Tabulaturblätter zum Song „Catch The Wind“</strong> – speziell erstellt für den Unterricht und das Selbststudium.
  </p>
  <ul>
    <li>Gitarren-Noten & Tabulatur</li>
    <li>Bassnoten</li>
    <li>Mundharmonika Solo</li>
  </ul>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach der erfolgreichen PayPal-Zahlung erhältst du sofort Zugriff auf die Downloads.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF und MP3 zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
  ogImage={ogImage}
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    pageTitle={pageTitle}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
  />
</BaseLayout>