---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Bossa Dorado – Noten & Tabulatur kaufen";
const description =
  "Kaufe die Noten & Tabulaturen für ‚Bossa Dorado‘ direkt hier. Nach der Zahlung erhältst du Zugriff auf die Downloads.";
const keywords = "Bossa Dorado, Noten & Tabulaturen, Gitarre, PDF";
const pageUrl = getPageUrl(Astro);
const returnUrl =
  "https://www.musicstudio-ziebart.de/kurse/thanks-bossa-dorado/";
const imageSrc = "/bilder/bossa_dorado_vorschau.png";
const imageAlt = "Bossa Dorado – Vorschau";
const price = "4.95";

const contentHtml = `
  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/1s2QSPskM0KAVRmRuQjgEkftCBnX7ERHN/preview"
    width="60%"
    height="50"
  ></iframe>

  <p>
  <a
    href="https://www.youtube.com/watch?v=LYOEuto28l8"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Bossa Dorado ansehen"
    rel="noopener"
  >
    ▶️ Bossa Dorado – Guitar Tutorial auf YouTube ansehen
  </a>
  </p>
  <p>
    Nach der Zahlung erhältst du sofortigen Zugriff auf die PDF Downloads. <br />
    Perfekt für Gitarristen, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten- &amp; Tabulaturblätter zum Song „Bossa Dorado“</strong>
    für Gypsy Jazz Guitar und Jazz Guitar – speziell erstellt für Unterricht und Selbststudium.
  </p>
  
  <ul>
    <li>Gitarren-Noten Solo Guitar</li>
    <li>Gitarren-Noten Rhythmus Guitar</li>
    <li>Bass-Noten</li>
    <li>Drums-Noten</li>
    <li>Audioaufnahme mp3</li>
    <li>Backing Track mp3</li>
  </ul>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach der erfolgreichen PayPal-Zahlung erhältst du sofort Zugriff auf die Downloads.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF und MP3 zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    pageTitle={pageTitle}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
  />
</BaseLayout>
