---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../../utils/getPageUrl.js";

const pageTitle = "Jazzguitar Lernmodule";
const description =
  "Lerne Gitarre mit strukturierten Lernmodulen: Strumming, Fingerstyle, Country und Blues – nach Stil und Level sortiert.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="website"
>

  <p>
    Hier findest du Jazz Gitarren Stücke und Übungen im Stil von Jazz.
    Schwerpunkt: Melodie-Spiel und Jazz Guitar Solo.
  </p>

  <!-- 🔷 Lernwege / Kategorien -->
  <h2>Rubriken</h2>

  <div class="card-grid">

    <div class="basis-card">
      <h2>Jazz Guitar Solo</h2>

      <p>
        Melodie-Spiel im Stil von Charlie Christian.
      </p>

      <ul>
        <li>
          <a href="/arrangements/rose-room/">
            Rose Room – Charlie Christian Gitarren Solo
          </a>
        </li>
      </ul>
    </div>

    
    <div class="basis-card">
      <h3>Melodic Style</h3>

      <p>Typischer Stil in dem die Jazz Gitarre die Melodie gleich mitspielt.</p>

      <ul>
        <li>
          <a href="/arrangements/smile/">
            Smile – Charlie Chaplin
          </a>
        </li>
      </ul>
      <li>
          <a href="/arrangements/what-a-wonderful-world/">
            What A Wonderful World – Louis Armstrong
          </a>
        </li>
      </ul>
    </div>

  </div>

  <!-- 🔷 Optional: Erklärung -->
  <h2>Wie funktioniert das Lernen?</h2>

  <ul>
    <li>Du wählst einen Stil (z. B. Melodic Style)</li>
    <li>Du lernst anhand eines konkreten Arrangements</li>
    <li>Du arbeitest mit echten Songs – ohne komplizierte Theorie</li>
  </ul>

</BaseLayout>