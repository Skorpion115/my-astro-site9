---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Like Ice In The Sunshine – Noten & Pattern kaufen";
const heading = "Like Ice In The Sunshine - Noten & Tabulaturen kaufen";
const description =
  "Kaufe die Noten & Tabulaturen für ‚Like Ice In The Sunshine‘ direkt hier. Nach der Zahlung erhältst du Zugriff auf die Downloads.";
const keywords = "Like Ice In The Sunshine, Noten & Tabulaturen, Gitarre, PDF";
const pageUrl = getPageUrl(Astro);
const returnUrl =
  "https://www.musicstudio-ziebart.de/kurse/thanks-like-ice-in-the-sunshine/";

const imageSrc = "/bilder/Like_Ice_Vorschau.jpg";
const imageAlt = "Like Ice In The Sunshine – Vorschau";
const price = "5.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/like_ice_in_the_sunshine_preview.png";

const contentHtml = `
  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/1FStHNYOBZz5WyhRwXl7RZkGcgNAxlhuw/preview"
    width="60%"
    height="50"
  ></iframe>

  <p>
  <a
    href="https://www.youtube.com/watch?v=Jk6ECVwJyZk"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Like Ice In The Sunshine ansehen"
    rel="noopener"
  >
    ▶️ Like Ice In The Sunshine – Guitar Tutorial auf YouTube ansehen
  </a>
  </p>
  <p>
    Nach der Zahlung erhältst du sofortigen Zugriff auf die PDF Downloads. <br />
    Perfekt für Gitarristen, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten- &amp; Tabulaturblätter zum Song „Like Ice In The Sunshine“</strong> – speziell erstellt für den Unterricht und das Selbststudium.
  </p>
  <ul>
    <li>Gitarre-Noten</li>
    <li>Audioaufnahme mp3</li>
    <li>Backing Track</li>
  </ul>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach der erfolgreichen PayPal-Zahlung erhältst du sofort Zugriff auf die Downloads.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF und MP3 zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
  />
</BaseLayout>