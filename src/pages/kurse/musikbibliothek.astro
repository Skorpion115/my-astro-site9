---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Musikbibliothek – Noten, Tabs & Lernmaterialien";
const description = "Musikbibliothek mit Noten, Tabs und Lernmaterialien für Gitarre, Klavier, Keyboard und mehr. Sofort als PDF verfügbar.";
const keywords = "Notenbücher, Musiknoten, Gitarrennoten, Download Noten";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="website"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>

  <p>
    Hier findest du strukturierte Lernmodule, Noten und Tabs für Gitarre, Klavier und weitere Instrumente.
    Alle Inhalte stehen dir digital zur Verfügung und sind sofort abrufbar.
  </p>

  <p>
    Ideal für Unterricht, Selbststudium und musikalische Weiterentwicklung.
  </p>

  <h2>Digitale Lerninhalte für Musiker</h2>

  <p>
   Die Musikbibliothek enthält eine Sammlung aus Noten, Tabs und Lernmaterialien, die sowohl im Unterricht als auch im Selbststudium verwendet werden können.
  </p>

  <p>
    Die Inhalte sind klar strukturiert und sofort digital verfügbar.
  </p>

  <h2>Für Unterricht und eigenes Lernen geeignet</h2>

  <ul>
    <li>Für Musikunterricht einsetzbar</li>
    <li>Für Selbststudium geeignet</li>
    <li>Strukturiert nach Instrumenten und Songs</li>
    <li>Digitale Bereitstellung ohne Wartezeit</li>
  </ul>

  <h2>Jetzt Musikbibliothek entdecken</h2>

  <p>
    Wähle dein Instrument und starte mit den passenden Lerninhalten und Noten zu deinen Lieblingssongs.
  </p>

  <h2>Sofortiger Zugriff auf alle Inhalte</h2>

  <p>
    Nach dem Kauf stehen dir alle Noten und Tabs direkt als PDF-Download zur
    Verfügung. Kein Abo, keine Registrierung nötig, kein Warten.
  </p>

  <ul>
    <li>Sofortiger Download nach Kauf</li>
    <li>PDF-Dateien für Gitarre, Klavier & mehr</li>
    <li>Originalgetreue Arrangements</li>
    <li>Ideal für Anfänger & Fortgeschrittene</li>
  </ul>

  <h2>Wähle dein Instrument</h2>

  <p>Finde schnell die passenden Noten & Tabs:</p>

  <!-- Navigation statt Song-Inhaltsverzeichnis -->
  <nav aria-label="Lernkategorien">
    <ul>
      <li>
        <a href="/kurse/gitarre/" class="cta-button"
          >Akustik Gitarrennoten & Tabs</a>
      </li>
      <li>
        <a href="/kurse/e-gitarre/" class="cta-button">E-Gitarren Tabs</a>
      </li>
      <li>
        <a href="/kurse/jazzguitar/" class="cta-button">Jazz Gitarren Tabs</a>
      </li>
      <li><a href="/kurse/piano/" class="cta-button">Klaviernoten</a></li>
      <li>
        <a href="/kurse/keyboard/" class="cta-button">Keyboard / Orgelnoten</a>
      </li>
      <li><a href="/kurse/banjo/" class="cta-button">Banjo Tabs</a></li>
      <li><a href="/kurse/akkordeon/" class="cta-button">Akkordeonnoten</a></li>
    </ul>
  </nav>

  <h2>Warum unsere Musikbibliothek?</h2>

  <ul>
    <li>Direkter Download ohne Wartezeit</li>
    <li>Strukturiert nach Songs und Stilrichtungen</li>
    <li>Perfekt für Selbststudium und Unterricht</li>
    <li>Regelmäßig neue Songs verfügbar</li>
  </ul>

  <h2>Jetzt starten</h2>

  <p>
    Wähle deinen Song und greife sofort auf die passenden Noten, Tabs und Lernmaterialien zu.
  </p>

  <p>
    Musikbibliothek für Gitarrennoten, Klaviernoten und Tabs als PDF Download.
    Sofort verfügbar, ohne Abo und ohne Registrierung. Ideal für Musiker, die
    direkt losspielen möchten.
  </p>
</BaseLayout>
