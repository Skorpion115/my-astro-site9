---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Musik Lernbibliothek";
const description = "Strukturierte Lernmodule für Gitarre, Keyboard, Jazz und mehr – nach Stil, Technik und Level sortiert.";
const keywords = "Notenbücher, Musiknoten, Gitarrennoten, Download Noten";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="website"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>

  <p>
    Hier findest du alle Lernmodule nach Stil, Technik und Instrument sortiert.
    Kein Abo, direkter Zugriff auf alle Inhalte.
  </p>

  <!-- Navigation statt Song-Inhaltsverzeichnis -->
  <nav aria-label="Lernkategorien">
    <ul>
      <li><a href="/kurse/gitarre/">Gitarre Lernmodule</a></li>
      <!--
      <li><a href="/kurse/keyboard/">Keyboard Lernmodule</a></li>
      <li><a href="/kurse/jazz/">Jazz Lernmodule</a></li>
      <li><a href="/kurse/country/">Country Lernmodule</a></li> -->
    </ul>
  </nav>
