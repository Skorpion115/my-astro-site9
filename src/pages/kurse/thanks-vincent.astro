---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Danke – Dein Download ist bereit";
const description =
  "Vielen Dank für deine Zahlung! Dein Noten- & Tabulaturblatt ‚Vincent‘ ist jetzt zum Download verfügbar.";
const keywords = "Vincent, Noten, Tabulatur, Download Noten, PDF";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="website"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
  noindex={true}
>
  <h1>Danke für deine Zahlung!</h1>

  <h2>Deine Downloads</h2>

  <p><strong>Der Download startet sofort, wenn du auf eine Datei klickst.</strong></p>

  <ul>
    <li>
      <a href="https://drive.google.com/uc?export=download&id=1zv-PpF8L6I6IX-eEnWc2M3jH7w6e8xcp"  class="cta-button">
        📄 Vincent – Noten & Tabulatur
      </a>
    </li>
    <li>
      <a href="https://drive.google.com/uc?export=download&id=1Yj9WMxOhoPViUNYdtxwKx8twUYDVsMa4" class="cta-button">
        📄 Vincent – Lead Sheet
      </a>
    </li>
  </ul>

  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>
</BaseLayout>