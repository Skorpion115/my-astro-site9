---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Hammond Flip – Klaus Wunderlich Noten für Orgel oder Keyboard kaufen";
const heading = "Hammond Flip - Klaus Wunderlich Noten kaufen";
const description =
  "Kaufe die Noten für ‚Hammond Flip‘ direkt hier. Nach der Zahlung erhältst du Zugriff auf die Downloads.";
const keywords = "Hammond Flip, Klaus Wunderlich, Noten, Keyboard, Orgel PDF";
const pageUrl = getPageUrl(Astro);
const returnUrl =
  "https://www.musicstudio-ziebart.de/kurse/thanks-hammond-flip/";

const imageSrc = "/bilder/Hammond_Flip_Vorschau.jpg";
const imageAlt = "Hammond Flip – Vorschau";
const price = "7.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/hammond_flip_preview.png";

const contentHtml = `
  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/1t78ztmJQ1Qpx6NErVMyF7jJn0zm6cvoX/preview"
    width="60%"
    height="50"
  ></iframe>

  <p>
  <a
    href="https://www.youtube.com/watch?v=244HlpB3JoA"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Hammond Flip ansehen"
    rel="noopener"
  >
    ▶️ Hammond Flip – Klaus Wunderlich Tutorial auf YouTube ansehen
  </a>
  </p>
  <p>
    Nach der Zahlung erhältst du sofortigen Zugriff auf die PDF Downloads. <br />
    Perfekt für Keyboardspieler/Organisten, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten zum Song „Hammond Flip“</strong> – speziell erstellt für den Unterricht und das Selbststudium.
  </p>
  <ul>
    <li>Keyboard/Orgel-Noten</li>
    <li>Audioaufnahme mp3</li>
  </ul>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach der erfolgreichen PayPal-Zahlung erhältst du sofort Zugriff auf die Downloads.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF und MP3 zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
  />
</BaseLayout>