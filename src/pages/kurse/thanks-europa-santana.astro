---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Danke – Dein Download ist bereit";
const description = "Vielen Dank für deine Zahlung! Dein Noten- & Tabulaturblatt ‚Europa‘ ist jetzt zum Download verfügbar.";
const keywords = "Europa, Noten, Tabulatur, Download Noten, PDF";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="website"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
  noindex={true}
>
  <h1>Danke für deine Zahlung!</h1>

  <h2>Deine Downloads</h2>

  <p><strong>Der Download startet sofort, wenn du auf eine Datei klickst.</strong></p>

  <ul>
    <li>
      <a href="https://drive.google.com/uc?export=download&id=1VwubHEilLW62QXcx7y-yHVYMNRqnHgL8"  class="cta-button" download  class="cta-button">
        📄 Europa Guitar
      </a>
    </li>
    <li>
      <a href="https://drive.google.com/uc?export=download&id=1BuVrm1GzhuVB9dUjstnab3wMgK1S6XyY"  class="cta-button">
        📄 Europa – Organ Noten
      </a>
    </li>
    <li>
      <a href="https://drive.google.com/uc?export=download&id=18xsh6nLLJgFuJWCkZKNp6XFnuyInrpfG"  class="cta-button">
        📄 Europa – Strings Noten
      </a>
    </li>
    <li>
      <a href="https://drive.google.com/uc?export=download&id=1yxJlrAg1kVuzU8cuscbLhiO2u7F1OGEM"  class="cta-button">
        📄 Europa – Bass Noten
      </a>
    </li>
    <li>
      <a href="https://drive.google.com/uc?export=download&id=17uv7XOCg6YCzPCs2r5eI5qb6k4M-lu5H"  class="cta-button">
        📄 Europa – Drums Noten
      </a>
    </li>
  </ul>

  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>
</BaseLayout>