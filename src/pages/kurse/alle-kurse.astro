---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";
const pageTitle = "Inhaltsverzeichnis der Kurse";
const description =
  "Sofort auf Notenbücher und Musiknoten zugreifen – ohne Abo, ohne automatische Verlängerung.";
const keywords = "Notenbücher, Musiknoten, Gitarrennoten, Download Noten";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="website"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <span id="top"></span>
  <p>
    Nach dem Kauf erhalten Sie direkten Zugriff auf alle Noten und Playbacks –
    ganz ohne Abo.
  </p>

  <ul>
    <li>✅ Sicher bezahlen</li>
    <li>✅ Sofortiger Zugriff auf alle Noten und Playbacks</li>
    <li>✅ Zugang für einen unbegrenzten Zeitraum</li>
  </ul>

  <p>
    Du behältst jederzeit die volle Kontrolle. Kein Zeitdruck, kein
    Kleingedrucktes.
  </p>

  <!-- Inhaltsverzeichnis: Desktop und Mobile -->
  <nav class="toc-desktop" aria-label="Inhaltsverzeichnis">
    <ul>
      <li>
        <a href="#banjo-5-string" class="normal-links">5-string Banjo Kurse</a>
      </li>
    </ul>
  </nav>

  <details class="toc-mobile" role="navigation" aria-label="Inhaltsverzeichnis">
    <summary>Inhaltsverzeichnis</summary>
    <ul>
      <li>
        <a href="#banjo-5-string" class="normal-links">5-string Banjo Kurse</a>
      </li>
    </ul>
  </details>

  <p>
    <strong>Jetzt direkt spielen!</strong>
  </p>

  <table class="basis-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Titel</th>
        <th>Komponist</th>
        <th>Instrument</th>
      </tr>
    </thead>
    <tbody>
      <tr style="display:none;">
        <td>1</td>
        <td data-label="Titel">Hammond Flip</td>
        <td data-label="Komponist">Klaus Wunderlich</td>
        <td data-label="Instrument">Organ/Keyboard</td>
      </tr>
      <tr style="display:none;">
        <td></td>
        <td data-label="anhören">
          <a
            href="https://drive.google.com/file/d/1t78ztmJQ1Qpx6NErVMyF7jJn0zm6cvoX/preview"
            class="normal-links"
          >
            "Hammond Flip" anhören
          </a>
        </td>
        <td data-label="ansehen">
          <a href="/kurse/hammond-flip-noten/" class="normal-links">Kaufen</a>
        </td>
        <td data-label="download">
          <a
            href="https://www.youtube.com/watch?v=244HlpB3JoA"
            class="normal-links"
            target="_blank"
            aria-label="YouTube Video zu Hammond Flip ansehen"
            rel="noopener">YouTube Video: Hammond Flip</a
          >
        </td>
      </tr>

      
    </tbody>
  </table>
  <!-- Variante A gefaltet -->
  <br />
  

