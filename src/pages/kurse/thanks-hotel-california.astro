---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Danke – Dein Download ist bereit";
const description = "Vielen Dank für deine Zahlung! Dein Noten- & Tabulaturblatt ‚Hotel California‘ ist jetzt zum Download verfügbar.";
const keywords = "Hotel California, Noten, Tabulatur, Download Noten, PDF";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="website"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
  noindex={true}
>
  <h1>Danke für deine Zahlung!</h1>

  <h2>Deine Downloads</h2>

  <p><strong>Der Download startet sofort, wenn du auf eine Datei klickst.</strong></p>

  <ul>
    <li>
      <a href="/notes/Hotel_California_Guitar_2.pdf" download  class="cta-button">
        📄 Hotel California Guitar 2
      </a>
    </li>
    <li>
      <a href="https://drive.google.com/uc?export=download&id=10nERjWm4X0ELS06CEELPNI_YhcI0A5y7"  class="cta-button">
        📄 Hotel California – Guitar 1
      </a>
    </li>
    <li>
      <a href="https://drive.google.com/uc?export=download&id=1EVRXv_kZYkxZF4khbqYnuXWCnbUKe5Gu"  class="cta-button">
        📄 Hotel California – Guitar Solo
      </a>
    </li>
    <li>
      <a href="https://drive.google.com/uc?export=download&id=1phuU-stLxFayQjPSAtcY2nHzNLFokxpq"  class="cta-button">
        📄 Hotel California – Bass Noten
      </a>
    </li>
    <li>
      <a href="https://drive.google.com/uc?export=download&id=1CEdCsFVCPJOpwS6Z5EJHjM23dc5wN5qk"  class="cta-button">
        📄 Hotel California – Lead Sheet
      </a>
    </li>
  </ul>

  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>
</BaseLayout>