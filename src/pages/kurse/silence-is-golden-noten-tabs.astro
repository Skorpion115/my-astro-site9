---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Silence Is Golden – Tremeloes komplettes Arrangement kaufen";
const heading = "Silence Is Golden - Tremeloes Noten & Tabulaturen kaufen";
const description =
  "Kaufe die Noten & Tabulaturen für ‚Silence Is Golden‘ direkt hier. Nach der Zahlung erhältst du Zugriff auf die Downloads.";
const keywords = "Silence Is Golden, Tremeloes, Noten & Tabulaturen, Gitarre, PDF";
const pageUrl = getPageUrl(Astro);
const returnUrl =
  "https://www.musicstudio-ziebart.de/kurse/thanks-silence-is-golden/";

const imageSrc = "/bilder/Silence_Is_Golden_Vorschau.jpg";
const imageAlt = "Silence Is Golden – Vorschau";
const price = "5.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/silence_is_golden_preview.png";

const contentHtml = `
  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/1OsFtazOaWIKphqXaDHqeQGXZrJKt2RgP/preview"
    width="60%"
    height="50"
  ></iframe>

  <p>
  <a
    href="https://www.youtube.com/watch?v=OxBca9ZfFv8"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Silence Is Golden ansehen"
    rel="noopener"
  >
    ▶️ Silence Is Golden – Gitarre Tutorial auf YouTube ansehen
  </a>
  </p>

  <p>
    Nach der Zahlung erhältst du sofortigen Zugriff auf die PDF Downloads. <br />
    Perfekt für Gitarristen, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten- &amp; Tabulaturblätter zum Song „Silence Is Golden“</strong> – speziell erstellt für den Unterricht und das Selbststudium.
  </p>
  <!--
  <ul>
    <li>Steelguitar-Noten</li>
    <li>E-Guitar-Noten</li>
    <li>Bass-Noten</li>
    <li>Drums-Noten</li>
    <li>Choir-Noten</li>
    <li>Audioaufnahme mp3</li>
    <li>Backing Track</li>
  </ul> -->
 
  <p>
    Gitarren-Noten (Akustik/E-Gitarre) mit Akkorden, TABs und Begleitmustern + Chorgesang + Bass Noten als PDF-Download. Enthält optional Hörbeispiel und eigenen Backing Track zur Lernunterstützung.
  </p>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach der erfolgreichen PayPal-Zahlung erhältst du sofort Zugriff auf die Downloads.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF und MP3 zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
  ogImage={ogImage}
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
  />
</BaseLayout>