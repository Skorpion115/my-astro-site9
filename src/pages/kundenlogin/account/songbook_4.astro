---
import AccountLayout from "../../../layouts/AccountLayout.astro";
import { getPageUrl } from "../../../utils/getPageUrl.js";

// Hier die fehlende Variable definieren
const pageUrl = getPageUrl(Astro);
const pageTitle = "My E-Guitar Collection";
const description = "Geschützter Songbook-Bereich";
---

<AccountLayout
  pageTitle="My E-Guitar Collection"
  description="Geschütztes Songbook 2"
  href={pageUrl}
>
  <link rel="stylesheet" href="/styles/songbook_2.css" />

  <div class="songbook-hero">
    <img src="/images/Gretchgitarre.webp" alt="The Big E-Guitar Songbook Cover" />
    <div class="hero-overlay">
      <h1 id="top">{pageTitle}</h1>
      <p>E-Gitarren Stücke • Noten & Tabs • Play-Alongs</p>
    </div>
  </div>
  
  <p>
    <a
      href="/kundenlogin/account/"
      class="normal-links"
      aria-label="Zurück zum Schülerbereich"
    >
      Zurück zum Schülerbereich
    </a>
  </p>

  <!-- Logout-Button -->
  <div class="logout-container">
    <button class="auth-logout">Logout</button>
  </div>

  <main>
    <!-- ======================== -->
    <!-- SONGBOOK LAYOUT -->
    <!-- ======================== -->
    <p>
      Recht im Inhaltsverzeichnis die Titel auswählen. Die Noten werden dann
      auf der linken Seite angezeigt. Ganz rechts ist so ein blauer ovaler
      Button. Mit diesem Button kann man die website wieder ganz nach oben
      scrollen.
    </p>


    <div class="lesson-layout">
      <!-- Linke Spalte -->
      <div class="notes-column">
        <!-- Linke Spalte: Noten + Audio -->
        <div class="notes">
          <section id="all-you-need-is-love" class="song">
            <h2>All You Need Is Love</h2>
            <p class="pdf-download">
              <a href="https://drive.google.com/file/d/1Sw2nnL3f51sz4uNZPW9KYrDFO_buy7ad/preview"
              >⬇ Noten Vorschau
              </a>
            </p>
            <div class="audio-links">
              <a
                href="https://drive.google.com/file/d/1Xrlh0BEM9SkFppr6kcPNQsYg_fHkibKC/preview"
                >▶ Play Along</a
              >
            </div>
            <div class="audio-links">
              <a
                href="https://drive.google.com/uc?export=download&id=1Xrlh0BEM9SkFppr6kcPNQsYg_fHkibKC"
                >▶ Audio downloaden</a
              >
            </div>
            <div class="audio-links">
              <a
                href="https://drive.google.com/uc?export=download&id=1nHGg_lb0se4zhDHeWv-e5e7ihsrrjbOP"
                >▶ Komplettes Arrangment downloade</a
              >
            </div>
            <!--
            <iframe
              src="https://drive.google.com/file/d/1GSGhDuWs5K_lh0KAyEF76IvjrS16lFmS/preview"
              title="Take Good Care Of My Baby – Noten"></iframe> -->

            <p class="pdf-link">
              <a 
                href="https://drive.google.com/uc?export=download&id=1GSGhDuWs5K_lh0KAyEF76IvjrS16lFmS"
                target="_blank"
                rel="noopener">
                📄 Noten herunterladen
              </a>
            </p>
          </section>
          <section id="take-good-care-of-my-baby" class="song">
            <h2>Take Good Care Of My Baby</h2>
            <p class="pdf-download">
              <a href="https://drive.google.com/file/d/1GSGhDuWs5K_lh0KAyEF76IvjrS16lFmS/preview"
              >⬇ Noten Vorschau
              </a>
            </p>
            <div class="audio-links">
              <a
                href="https://drive.google.com/file/d/1ZFpf760L5VRlUhBSn3MIQ0Ij8114ar-S/preview"
                >▶ Play Along</a
              >
            </div>
            <div class="audio-links">
              <a
                href="https://drive.google.com/uc?export=download&id=1ZFpf760L5VRlUhBSn3MIQ0Ij8114ar-S"
                >▶ Audio downloaden</a
              >
            </div>
            <div class="audio-links">
              <a
                href="https://drive.google.com/uc?export=download&id=1ABvwLJT44oSwGtwgv5pRN2VK3exhXbYS"
                >▶ Komplettes Arrangment downloade</a
              >
            </div>
            <p class="pdf-link">
              <a 
                href="https://drive.google.com/uc?export=download&id=1GSGhDuWs5K_lh0KAyEF76IvjrS16lFmS"
                target="_blank"
                rel="noopener">
                📄 Noten herunterladen
              </a>
            </p>
          </section>
           <section id="ten-words" class="song">
            <h2>Ten Words</h2>
            <p class="pdf-download">
              <a href="https://drive.google.com/file/d/1rjp3GTNeJrgPzwMVTCmSGzIcdhgmuf7I/preview"
              >⬇ Tab Vorschau
              </a>
            </p>
            <div class="audio-links">
              <a
                href="https://drive.google.com/file/d/1qOK0uBVYixUAwysHQYBbzfOIz80M7WYv/preview"
                >▶ Play Along</a
              >
            </div>
            <div class="audio-links">
              <a
                href="https://drive.google.com/uc?export=download&id=1qOK0uBVYixUAwysHQYBbzfOIz80M7WYv"
                >▶ Audio downloaden</a
              >
            </div>
            <div class="audio-links">
              <a
                href="https://drive.google.com/uc?export=download&id=1OkxTSKDodYBm0-zWKd9xh8a3neg2BLj6"
                >▶ Backing Track downloaden</a
              >
            </div>
            <p class="pdf-link">
              <a 
                href="https://drive.google.com/uc?export=download&id=1rjp3GTNeJrgPzwMVTCmSGzIcdhgmuf7I"
                target="_blank"
                rel="noopener">
                📄 Tab herunterladen
              </a>
            </p>
          </section>
            
         
          
        </div> <!-- class notes -->
      </div> <!-- class notes-column -->
      <!-- Rechte Spalte: Inhaltsverzeichnis -->
      <aside class="content">
        <h3>Inhaltsverzeichnis</h3>
        <h4>Popmusik</h4>
        <a href="#all-you-need-is-love">All You Need Is Love - Beatles</a>
        <a href="#take-good-care-of-my-baby">Take Good Care Of My Baby - Bobby Vee</a>
        <a href="#ten-words">Ten Words - Jo Satriani</a>
      </aside>
      <a href="#top" class="scroll-top" aria-label="Zurück nach oben">⬆</a>
    </div> <!-- class lesson-layout -->
  </main>
  
  <script src="/scripts/login.js" defer></script>
  <script src="/scripts/scroll-offset.js" defer></script>
</AccountLayout>
