<AccountLayout
  pageTitle="My Jazz Guitar Collection"
  description="Geschütztes Songbook 5"
  href={pageUrl}
>
  <link rel="stylesheet" href="/styles/songbook_2.css" />

  <div class="songbook-hero">
    <img src="/images/jazzguitar.webp" alt="The Jazz Guitar Collection" />
    <div class="hero-overlay">
      <h1 id="top">{pageTitle}</h1>
      <p>Jazz Gitarren Stücke • Noten & Tabs • Play-Alongs</p>
    </div>
  </div>
  
  <p>
    <a
      href="/kundenlogin/account/"
      class="normal-links"
      aria-label="Zurück zum Schülerbereich"
    >
      Zurück zum Schülerbereich
    </a>
  </p>

  <!-- Logout-Button -->
  <div class="logout-container">
    <button class="auth-logout">Logout</button>
  </div>

