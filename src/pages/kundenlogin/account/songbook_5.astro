---
import AccountLayout from "../../../layouts/AccountLayout.astro";
import { getPageUrl } from "../../../utils/getPageUrl.js";

// Hier die fehlende Variable definieren
const pageUrl = getPageUrl(Astro);
const pageTitle = "My Jazz Guitar Collection";
const description = "Geschützter Songbook-Bereich";
---

<AccountLayout
  pageTitle="My Jazz Guitar Collection"
  description="Geschütztes Songbook 5"
  href={pageUrl}
>
  <link rel="stylesheet" href="/styles/songbook_2.css" />

  <div class="songbook-hero">
    <img src="/images/jazzguitar.webp" alt="The Jazz Guitar Collection" />
    <div class="hero-overlay">
      <h1 id="top">{pageTitle}</h1>
      <p>Jazz Gitarren Stücke • Noten & Tabs • Play-Alongs</p>
    </div>
  </div>
  
  <p>
    <a
      href="/kundenlogin/account/"
      class="normal-links"
      aria-label="Zurück zum Schülerbereich"
    >
      Zurück zum Schülerbereich
    </a>
  </p>

  <!-- Logout-Button -->
  <div class="logout-container">
    <button class="auth-logout">Logout</button>
  </div>

  <main>
    <!-- ======================== -->
    <!-- SONGBOOK LAYOUT -->
    <!-- ======================== -->
    <p>
      Recht im Inhaltsverzeichnis die Titel auswählen. Die Noten werden dann
      auf der linken Seite angezeigt. Ganz rechts ist so ein blauer ovaler
      Button. Mit diesem Button kann man die website wieder ganz nach oben
      scrollen.
    </p>


    <div class="lesson-layout">
      <!-- Linke Spalte -->
      <div class="notes-column">
        <!-- Linke Spalte: Noten + Audio -->
        <div class="notes">
          <section id="rose-room" class="song">
            <h2>Rose Room</h2>
            <p class="pdf-download">
              <a href="https://drive.google.com/file/d/1dgIAZYebkFhFNlx4kGz9LsGx2-nWsKpM/preview"
              >⬇ Noten Vorschau
              </a>
            </p>
            <div class="audio-links">
              <a
                href="https://drive.google.com/file/d/155_Ji0iFSFKAkeEHK8xL44p-uImeTfv7/preview"
                >▶ Play Along</a
              >
            </div>
            <div class="audio-links">
              <a
                href="https://drive.google.com/uc?export=download&id=155_Ji0iFSFKAkeEHK8xL44p-uImeTfv7"
                >▶ Audio downloaden</a
              >
            </div>
            <div class="audio-links">
              <a
                href="https://drive.google.com/uc?export=download&id=1dLA_Josn8d8wYLs95ueOz1Z4H7gxLVnP"
                >▶ Backing Track downloaden</a
              >
            </div>
            <p class="pdf-link">
              <a 
                href="https://drive.google.com/uc?export=download&id=1dgIAZYebkFhFNlx4kGz9LsGx2-nWsKpM"
                target="_blank"
                rel="noopener">
                📄 Noten herunterladen
              </a>
            </p>
            <p class="pdf-link">
              <a 
                href="https://drive.google.com/uc?export=download&id=1RI45csrN6b2BTLTQCC-g8S88d8tSUelD"
                target="_blank"
                rel="noopener">
                📄 Rhythmus Gitarre herunterladen
              </a>
            </p>
            <div class="video-container-wrapper thumbnail">
              <div class="video-container">
                <iframe
                  src="https://www.youtube.com/embed/__aCfS0Vd8U?start=42"
                  title="YouTube video player"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen></iframe>
              </div>
            </div>
            <p>
              Das Video kann man vergrößern, indem man auf das kleine Quadrat in der rechten unteren Ecke klickt. Es öffnet sich dann in einem neuen Tab und man kann es in voller Größe anschauen.
            </p>
