---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Danke – Dein Download ist bereit";
const description =
  "Vielen Dank für deine Zahlung! Dein Noten- & Tabulaturblatt ‚Catch The Wind‘ ist jetzt zum Download verfügbar.";
const keywords = "Catch The Wind, Noten, Tabulatur, Download Noten, PDF";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="website"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
  noindex={true}
>
  <h1>Danke für deine Zahlung!</h1>

  <h2>Deine Downloads</h2>

  <p><strong>Der Download startet sofort, wenn du auf eine Datei klickst.</strong></p>

  <ul>
    <li>
      <a href="/downloads/Catch_The_Wind_Guitar.pdf" download class="cta-button">
        📄 Catch The Wind – Noten & Tabulatur
      </a>
    </li>
    <li>
      <a href="/downloads/Catch_The_Wind_Bass.pdf" download class="cta-button">
        📄 Catch The Wind – Bass
      </a>
    </li>
    <li>
      <a href="https://drive.google.com/uc?export=download&id=19jXw9-t0b-TLr_2xsYvPAVHdw5exWBzW"
        class="cta-button"
        target="_blank"
        rel="noopener">
        🎵 Catch The Wind – Play Along
      </a>
    </li>
  </ul>

  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>
</BaseLayout>