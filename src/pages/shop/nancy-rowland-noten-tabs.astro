---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Nancy Rowland Banjo Solo – Tabulatur kaufen | Musicstudio Ziebart";
const description =
  "Banjosolo zu »Nancy Rowland« als PDF. Ideal für Bluegrass Banjo Picker. Sofort-Download nach Zahlung.";
const keywords =
  "Nancy Rowland, Banjo Solo, Bluegrass Banjo, Tabulatur, PDF Download";
const pageUrl = getPageUrl(Astro);

// Produktdaten (Kleinunternehmer §19 UStG)
const price = 2.50;

// Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/nancy_rowland_preview.png";

// PayPal-Daten
const itemName = "Nancy Rowland – Banjo Solo (PDF)";
const returnUrl = "https://www.musicstudio-ziebart.de/shop/thanks-nancy-rowland/";
const paypalBusiness = "musikstudio.ziebart@gmail.com";
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
  ogImage={ogImage}
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <h1>Nancy Rowland – Banjo Solo</h1>

  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/10BD_orSvPDHpAHCrgG1mr90J1CKk8NWZ/preview"
    width="60%"
    height="50"
  ></iframe>

  <p>
  <a
    href="https://www.youtube.com/watch?v=lFrx4fhty3A"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Nancy Rowland ansehen"
    rel="noopener"
  >
    ▶️ Nancy Rowland – Banjo Tutorial auf YouTube ansehen
  </a>
  </p>

  <p>
    Hol dir die <strong>Tabulatur zu »Nancy Rowland«</strong> für dein Banjospiel.
    <br />
    Sofortiger Download nach Zahlung.
  </p>

  <ul>
    <li>✔ Klar notiertes Banjo Solo</li>
    <li>✔ Für Unterricht & Selbststudium</li>
  </ul>

  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF und MP3 zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>

  <table class="price-table">
    <tr>
      <th>Produkt</th>
      <td>Nancy Rowland – Banjo Solo (PDF)</td>
    </tr>
    <tr>
      <th>Preis</th>
      <td><strong>{price.toFixed(2)} €</strong></td>
    </tr>
  </table>

  <p class="small">
    Gemäß § 19 Abs. 1 UStG wird keine Umsatzsteuer berechnet.
  </p>

  <!-- PayPal Button -->
  <form class="paypal-form"
    action="https://www.paypal.com/cgi-bin/webscr"
    method="post"
    target="_top"
  >
    <input type="hidden" name="cmd" value="_xclick" />
    <input type="hidden" name="business" value={paypalBusiness} />
    <input type="hidden" name="item_name" value={itemName} />
    <input type="hidden" name="amount" value={price} />
    <input type="hidden" name="currency_code" value="EUR" />
    <input type="hidden" name="return" value={returnUrl} />
    <input type="hidden" name="no_shipping" value="1" />
    <input type="hidden" name="charset" value="utf-8" />
    <input type="hidden" name="lc" value="DE" />

    <button type="submit" class="paypal-button">
      Jetzt mit PayPal kaufen
    </button>
  </form>

  <p>
    <a href="/kurse/alle-kurse/" class="normal-links">← Zurück zum Inhaltsverzeichnis</a>
  </p>
</BaseLayout>
