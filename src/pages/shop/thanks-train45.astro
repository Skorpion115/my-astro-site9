---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Download – Train 45 Banjo Solo";
const description =
  "Download der Banjo-Tabulatur »Train 45«. Vielen Dank für deinen Kauf.";
const keywords = "Train 45, Banjo Download, Tabulatur PDF";
const pageUrl = getPageUrl(Astro);
const downloads = [
  {
    label: "Train 45 – Banjo Solo (PDF)",
    url: "/downloads/Train_45.pdf",
  },
  {
    label: "Train 45 – Mastering (MP3)",
    url: "https://drive.google.com/uc?export=download&id=1XE5ZI3v9HD0QOTQ6XdRjge8R8TojXEmV",
  },
];
---
<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  noindex={true}
>
  <h1>Vielen Dank für deinen Kauf!</h1>

  <p>
    Du kannst deine <strong>Banjo-Tabulatur „Train 45 – Solo“</strong> jetzt
    herunterladen.
  </p>

  <hr />
  <ul>
    {
      downloads.map((file) => (
        <li>
          <a href={file.url} download class="download-button">
            👉 {file.label}
          </a>
        </li>
      ))
    }
  </ul>

  <p>
    👉 <strong>Wichtig:</strong> Bitte speichere die Datei direkt auf deinem
    Gerät ab.
  </p>

  <hr />

  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail:
    <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p class="vat-note">
    Rechnung mit ausgewiesener MwSt. auf Anfrage per E-Mail erhältlich.
  </p>

  <p>
    <a href="/" class="normal-links">← Zurück zur Startseite</a>
  </p>
</BaseLayout>
