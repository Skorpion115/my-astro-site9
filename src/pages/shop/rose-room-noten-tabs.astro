---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PaypalButton from "../../components/PaypalButton.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Rose Room Noten & BackingTrack kaufen | Musicstudio Ziebart";
const description = "Gitarrensolo zu »Rose Room« als PDF. Ideal für Jazz-Gitarre. Sofort-Download nach Zahlung.";
const keywords = "Rose Room, Guitar Solo, Jazz Gitarre, Gitarrennoten, PDF Download";
const pageUrl = getPageUrl(Astro);

// Produktdaten
const priceGross = "5,95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/rose_room_preview.png";

---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
  ogImage={ogImage}
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <h1>Rose Room – Guitar Solo</h1>

  <img
    src="/bilder/Anfang.jpg"
    alt="Rose Room – Jazz Guitar Solo Vorschau"
    class="product-image"
  />

  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/1zuALZWdEh62ylIP3JpZT-8GaGyHbRbHp/preview"
    width="60%"
    height="50"
  ></iframe>

  <p>
  <a
    href="https://www.youtube.com/watch?v=__aCfS0Vd8U"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Rose Room ansehen"
    rel="noopener"
  >
    ▶️ Rose Room – Guitar Tutorial auf YouTube ansehen
  </a>
  </p>

  <p>
    Hol dir die <strong>
      Noten Rose Room Jazz Guitar Solo + Rose Room Rhythm Guitar + Rose Room Bass +
      BackingTrack + Rose Room Mastering
    </strong> für dein Gitarrenspiel.
    <br />
    Sofortiger Download nach Zahlung.
  </p>

  <ul>
    <li>✔ Klar notiertes Guitar Solo</li>
    <li>✔ Für Unterricht & Selbststudium</li>
  </ul>

  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF und MP3 zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>

  <table class="price-table">
    <tr>
      <th>Produkt</th>
      <td>Rose Room – Guitar Solo (PDF)</td>
    </tr>
    <tr>
      <th>Gesamtpreis</th>
      <td><strong>{priceGross} €</strong></td>
    </tr>
  </table>

 <p class="small">
    Gemäß § 19 Abs. 1 UStG wird keine Umsatzsteuer berechnet.
  </p>

  <PaypalButton
    itemName="Rose Room – Guitar Solo (PDF)"
    amount={priceGross}
    returnUrl="https://www.musicstudio-ziebart.de/shop/thanks-rose-room/"
  />

  <p class="vat-note">
    <small>
      Rechnung auf Anfrage per E-Mail erhältlich.
    </small>
  </p>

  <p>
    <a href="/kurse/alle-kurse/#jazz-guitar" class="cta-button">
      Weitere Jazz Gitarrenstücke entdecken
    </a>
  </p>

  <p>
    <a href="/kurse/alle-kurse/" class="normal-links">← Alle Musikstücke anzeigen</a>
  </p>
</BaseLayout>
