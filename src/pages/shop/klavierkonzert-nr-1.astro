---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Klavierkonzert Nr. 1 in Bbm - Klavier Solo – Noten kaufen";
const description =
  "Klavier Solo zu »Klavierkonzert Nr. 1 in Bbm« als PDF. Ideal für Klavierunterricht & Selbststudium. Sofort-Download nach Zahlung.";
const keywords =
  "Klavierkonzert Nr. 1 in Bbm, Klavier Solo, Noten, PDF Download";
const pageUrl = getPageUrl(Astro);

// Produktdaten (sauber als Zahlen)
const priceGross = 4.95;


// PayPal-Daten
const itemName = "Klavierkonzert Nr. 1 in Bbm – Klavier Solo (PDF)";
const returnUrl = "https://www.musicstudio-ziebart.de/download/klavierkonzert-nr-1/";
const paypalBusiness = "musikstudio.ziebart@gmail.com";
---
<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <img
    src="/bilder/Klavierkonzert_Nr_1_Vorschau.png"
    alt="Klavierkonzert Nr. 1 in Bbm – Vorschau"
    class="product-image"
  />

  <p>
    Hol dir die <strong>Noten zu Klavierkonzert Nr. 1 in Bbm I. Satz - P. Tschaikowsky</strong> für zwei Hände. Ursprünglich ist das Stück für  vierhändiges Klavierspiel arrangiert, aber hier findest du die Noten für zwei Hände. Ich habe es umgeschrieben.
    <br />
    Sofortiger Download nach Zahlung.
  </p>

  <ul>
    <li>✔ Klar notiertes Klavier Solo</li>
    <li>✔ Für Unterricht & Selbststudium</li>
    <li>✔ Sofortiger Download nach Zahlung</li>
  </ul>

  <table class="price-table">
    <tr>
      <th>Produkt</th>
      <td>Klavierkonzert Nr. 1 in Bbm - I. Satz – Klavier Solo (PDF) P. Tschaikowsky</td>
    </tr>
    <tr>
      <th>Gesamtpreis</th>
      <td><strong>{priceGross.toFixed(2)} €</strong></td>
    </tr>
  </table>

 <p class="small">
    Gemäß § 19 Abs. 1 UStG wird keine Umsatzsteuer berechnet.
  </p>
  <!-- PayPal Button OHNE Komponente -->
  <form class="paypal-form"
    action="https://www.paypal.com/cgi-bin/webscr"
    method="post"
    target="_top"
  >
    <input type="hidden" name="cmd" value="_xclick" />
    <input type="hidden" name="business" value={paypalBusiness} />
    <input type="hidden" name="item_name" value={itemName} />
    <input type="hidden" name="amount" value={priceGross} />
    <input type="hidden" name="currency_code" value="EUR" />
    <input type="hidden" name="return" value={returnUrl} />
    <input type="hidden" name="no_shipping" value="1" />
    <input type="hidden" name="charset" value="utf-8" />
    <input type="hidden" name="lc" value="DE" />

    <button type="submit" class="paypal-button">
      Jetzt mit PayPal kaufen
    </button>
  </form>

  <p class="vat-note">
    <small>
      Rechnung auf Anfrage per E-Mail erhältlich.
    </small>
  </p>

  <p>
    <a href="/kunden-login/inhaltsverzeichnis/" class="normal-links">← Zurück zum Inhaltsverzeichnis</a>
  </p>
</BaseLayout>