---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Aus der neuen Welt - Klavier Solo – Noten kaufen | Musicstudio Ziebart";
const description =
  "Klavier Solo zu »Aus der neuen Welt« als PDF. Ideal für Klavierunterricht & Selbststudium. Sofort-Download nach Zahlung.";
const keywords =
  "Aus der neuen Welt, Klavier Solo, Noten, PDF Download";
const pageUrl = getPageUrl(Astro);

// Produktdaten (sauber als Zahlen)
const priceGross = 5.95;

// Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/dvorak_aus_der_neuen_welt_largo_preview.png";


// PayPal-Daten
const itemName = "Aus der neuen Welt – Klavier Solo (PDF)";
const returnUrl = "https://www.musicstudio-ziebart.de/shop/thanks-largo/";
const paypalBusiness = "musikstudio.ziebart@gmail.com";
---
<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
  igImage={ogImage}
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <img
    src="/bilder/Largo_Vorschau.png"
    alt="Largo – Vorschau"
    class="product-image"
  />

  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/1pJepIFMXiLfmynzJQefV6mGy4rekv-gm/preview"
    width="60%"
    height="50"
  ></iframe>

  <p>
  <a
    href="https://www.youtube.com/watch?v=ytcQ-I1BTNk"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Aus der neuen Welt ansehen"
    rel="noopener"
  >
    ▶️ Aus der neuen Welt – Klavier Solo auf YouTube ansehen
  </a>
  </p>

  <p>
    Hol dir die <strong>Noten zu Aus der neuen Welt II. Satz Klavier  Solo</strong> für dein Klavierspiel.
    <br />
    Sofortiger Download nach Zahlung.
  </p>

  <ul>
    <li>✔ Klar notiertes Klavier Solo</li>
    <li>✔ Für Unterricht & Selbststudium</li>
  </ul>

  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF und MP3 zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>

  <table class="price-table">
    <tr>
      <th>Produkt</th>
      <td>Aus der neuen Welt - II. Satz Largo – Klavier Solo (PDF)</td>
    </tr>
    <tr>
      <th>Gesamtpreis</th>
      <td><strong>{priceGross.toFixed(2)} €</strong></td>
    </tr>
  </table>

 <p class="small">
    Gemäß § 19 Abs. 1 UStG wird keine Umsatzsteuer berechnet.
  </p>
  <!-- PayPal Button OHNE Komponente -->
  <form class="paypal-form"
    action="https://www.paypal.com/cgi-bin/webscr"
    method="post"
    target="_top"
  >
    <input type="hidden" name="cmd" value="_xclick" />
    <input type="hidden" name="business" value={paypalBusiness} />
    <input type="hidden" name="item_name" value={itemName} />
    <input type="hidden" name="amount" value={priceGross} />
    <input type="hidden" name="currency_code" value="EUR" />
    <input type="hidden" name="return" value={returnUrl} />
    <input type="hidden" name="no_shipping" value="1" />
    <input type="hidden" name="charset" value="utf-8" />
    <input type="hidden" name="lc" value="DE" />

    <button type="submit" class="paypal-button">
      Jetzt mit PayPal kaufen
    </button>
  </form>

  <p class="vat-note">
    <small>
      Rechnung auf Anfrage per E-Mail erhältlich.
    </small>
  </p>

  <p>
    <a href="/kurse/alle-kurse/#klavier-kurse" class="cta-button">
      Weitere klassische Klavierstücke entdecken
    </a>
  </p>

  <p>
    <a href="/kurse/alle-kurse/" class="normal-links">← Alle Musikstücke zeigen</a>
  </p>
</BaseLayout>