---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle = "Download: Ferry Across The Mersey – Guitar Arrangement";
const description = "Hier kannst du dein gekauftes Arrangement herunterladen.";
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  ogType="article"
  bodyAttributes={{
    "data-product-id": "FERRY-001",
    "data-price": "9.95",
  }}
>
  <h1>Dein Download</h1>

  <p>Danke für deinen Kauf! Hier kannst du dein Arrangement herunterladen.</p>

  <h2>Download</h2>

  <ul>
    <li>
      <a
        href="/notes/Ferry%20Across%20The%20Mersey.pdf"
        download
        class="cta-button"
      >
        📄 Ferry Across The Mersey – Noten & Tabulatur
      </a>
    </li>
    <li>
      <a
        href="https://drive.google.com/uc?export=download&id=1_ZVNUmKHPScG2_t3ml0E2-N0c8_CupVC"
        class="cta-button"
      >
        📄 Ferry Across The Mersey – Komplettes Arrangment als ZIP Datei
      </a>
    </li>
  </ul>

  <h2>Hinweise</h2>

  <ul>
    <li>Einmal gekauft – dauerhaft verfügbar</li>
    <li>Keine Abo-Falle</li>
    <li>Nur für dich persönlich lizenziert</li>
  </ul>

  <script src="/scripts/purchase.js" defer></script>
</BaseLayout>
