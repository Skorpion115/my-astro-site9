---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Download – Nancy Rowland Banjo Solo";
const description =
  "Download der Banjo-Tabulatur »Nancy Rowland«. Vielen Dank für deinen Kauf.";
const keywords = "Nancy Rowland, Banjo Download, Tabulatur PDF";
const pageUrl = getPageUrl(Astro);
---
<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  noindex={true}
>
  <h1>Vielen Dank für deinen Kauf!</h1>

  <p>
    Du kannst deine <strong>Banjo-Tabulatur „Nancy Rowland – Solo“</strong> jetzt
    herunterladen.
  </p>

  <p>
    👉 <strong>Wichtig:</strong> Bitte speichere die Datei direkt auf deinem
    Gerät ab.
  </p>

  <hr />

  <p>
    <a
      href="https://www.musicstudio-ziebart.de/downloads/Nancy_Rowland_-_Snuffy_Jenkins.pdf"
      class="download-button"
      download
    >
      ⬇ Nancy Rowland – Banjo Solo (PDF) herunterladen
    </a>
  </p>

  <hr />

  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail:
    <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p class="vat-note">
    Rechnung mit ausgewiesener MwSt. auf Anfrage per E-Mail erhältlich.
  </p>

  <p>
    <a href="/" class="normal-links">← Zurück zur Startseite</a>
  </p>
</BaseLayout>