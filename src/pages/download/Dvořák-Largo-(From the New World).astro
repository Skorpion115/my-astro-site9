---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle =
  "Download: Dvořák - Largo from Symphony No. 9 'From the New World'";
const description = "Hier kannst du dein gekauftes Arrangement herunterladen.";
---

<BaseLayout pageTitle={pageTitle} description={description} ogType="article">
  <h1>Dein Download</h1>

  <p>Danke für deinen Kauf! Hier kannst du dein Arrangement herunterladen.</p>

  <h2>Deine Downloads</h2>

  <p>
    <a href="/downloads/Largo.pdf" class="cta-button">
      📄 Dvořák - Largo from Symphony No. 9 'From the New World'
    </a>
  </p>

  <p>
    <a
      href="https://drive.google.com/uc?export=download&id=1pJepIFMXiLfmynzJQefV6mGy4rekv-gm"
      class="cta-button"
      target="_blank"
      rel="noopener"
    >
      🎵 Dvořák - Largo from Symphony No. 9 'From the New World' – Mastering
    </a>
  </p>

  <h2>Hinweise</h2>

  <ul>
    <li>Einmal gekauft – dauerhaft verfügbar</li>
    <li>Keine Abo-Falle</li>
    <li>Nur für dich persönlich lizenziert</li>
  </ul>

  <p>
    <a href="/kurse/musikbibliothek/" class="cta-button">
      Kurse zum selber lernen: Alle Lernmodule auf einen Blick
    </a>
  </p>
</BaseLayout>
