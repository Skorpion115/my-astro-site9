const description = "Hier kannst du dein gekauftes Arrangement herunterladen.";
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  ogType="article"
  bodyAttributes={{
    "data-product-id": "WALHF-001",
    "data-price": "7.95",
  }}
>
  <h1>Dein Download</h1>

  <p>Danke für deinen Kauf! Hier kannst du dein Arrangement herunterladen.</p>

  <h2>Download</h2>

  <ul>
    <li>
      <a
        href="/notes/With%20A%20Little%20Help%20From%20My%20Friends.pdf"
        class="cta-button"
        download
        class="cta-button"
      >
        📄 With A Little Help From My Friends - Guitar
      </a>
    </li>
    <li>
      <a
        href="https://drive.google.com/uc?export=download&id=11z31BiCF2edm_z72FJVH2N6Q6drNiHkz"
        class="cta-button"
        download
        class="cta-button"
      >
        📄 With A Little Help From My Friends - Komplettes Arrangement als ZIP
      </a>
    </li>
  </ul>

  <h2>Hinweise</h2>

  <ul>
    <li>Einmal gekauft – dauerhaft verfügbar</li>
    <li>Keine Abo-Falle</li>
    <li>Nur für dich persönlich lizenziert</li>
  </ul>

  <script src="/scripts/purchase.js" defer></script>
</BaseLayout>
