---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Download: Imagine – John Lennon";
const description = "Download der Noten »Imagine«. Vielen Dank für Ihren Kauf.";
const keywords = "Für Imagine, Klavier Begleitung, Noten PDF";
const pageUrl = getPageUrl(Astro);
const downloads = [
  {
    label: "Imagine – Klavier Noten (PDF)",
    url: "https://drive.google.com/uc?export=download&id=1x6roFs1P8w5ca5UuhMZ6Cl9235E8k4K2",
  },
  {
    label: "Imagine – Komplettes Arrangement als ZIP",
    url: "https://drive.google.com/uc?export=download&id=19q90gGy3t-TNh2yqyEHn3_cP89takU16",
  },
];
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  noindex={true}
  bodyAttributes={{
    "data-product-id": "IMAG-001",
    "data-price": "7.95"
  }}
>
  <h1>Vielen Dank für deinen Kauf!</h1>

  <p>
    Du kannst deine <strong>Noten „Imagine – Klavier Begleitung“</strong> jetzt
    herunterladen.
  </p>

  <p>
    👉 <strong>Wichtig:</strong> Bitte speichere die Datei direkt auf deinem Gerät
    ab.
  </p>

  <hr />
  <ul>
    {
      downloads.map((file) => (
        <li>
          <a href={file.url} download class="download-button">
            👉 {file.label}
          </a>
        </li>
      ))
    }
  </ul>

  <hr />

  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail:
    <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p class="vat-note">
    Rechnung mit auf Anfrage per E-Mail erhältlich.
  </p>

  <p>
    <a href="/kurse/musikbibliothek/" class="normal-links">← Zurück zur Musikbibliothek</a>
  </p>
  <script src="/scripts/purchase.js" defer></script>
</BaseLayout>