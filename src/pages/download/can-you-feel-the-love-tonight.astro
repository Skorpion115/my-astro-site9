---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Download: Can You Feel The Love Tonight – Elton John";
const description = "Download der Noten »Can You Feel The Love Tonight«. Vielen Dank für Ihren Kauf.";
const keywords = "Can You Feel The Love Tonight, Klavier Begleitung, Noten PDF";
const pageUrl = getPageUrl(Astro);
const downloads = [
  {
    label: "Can You Feel The Love Tonight – Klavier Noten (PDF)",
    url: "https://drive.google.com/uc?export=download&id=1jUjJQD3GMVC_jAF2_3j7O72kW0qxurMx",
  },
  {
    label: "Can You Feel The Love Tonight – Querflöten Noten (PDF)",
    url: "https://drive.google.com/uc?export=download&id=1bSOGaDQQb8d4ObEHSV6fLa1YU7kALUIS",
  },
  {
    label: "Can You Feel The Love Tonight – Klarinetten Noten (PDF)",
    url: "https://drive.google.com/uc?export=download&id=1UR0aIUxFNZvMaqHV_NoM9GHXei7W0b3S",
  },
  {
    label: "Can You Feel The Love Tonight – Drums Noten (PDF)",
    url: "https://drive.google.com/uc?export=download&id=1RtsGBZM26eUdk1dNOb6kbx4sALDcTgD6",
  },
];
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  noindex={true}
  bodyAttributes={{
    "data-product-id": "CYFTLT-001",
    "data-price": "6.95"
  }}
>
  <h1>Vielen Dank für deinen Kauf!</h1>

  <p>
    Du kannst deine <strong>Noten „Can You Feel The Love Tonight – Klavier Begleitung“</strong> jetzt
    herunterladen.
  </p>

  <p>
    👉 <strong>Wichtig:</strong> Bitte speichere die Datei direkt auf deinem Gerät
    ab.
  </p>

  <hr />
  <ul>
    {
      downloads.map((file) => (
        <li>
          <a href={file.url} download class="download-button">
            👉 {file.label}
          </a>
        </li>
      ))
    }
  </ul>

  <hr />

  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail:
    <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p class="vat-note">
    Rechnung mit auf Anfrage per E-Mail erhältlich.
  </p>

  <p>
    <a href="/kurse/musikbibliothek/" class="normal-links">← Zurück zur Musikbibliothek</a>
  </p>
  <script src="/scripts/purchase.js" defer></script>
</BaseLayout>