---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle = "Download: Train 45";
const description = "Hier kannst du dein gekauftes Arrangement herunterladen.";
---

<BaseLayout pageTitle={pageTitle} 
  description={description} 
  ogType="article"
  bodyAttributes={{
    "data-product-id": "TRAIN-001"
  }}
>
  <h1>Dein Download</h1>

  <p>Danke für deinen Kauf! Hier kannst du dein Arrangement herunterladen.</p>

  <h2>Download</h2>

  <ul>
    <li>
      <a href="/downloads/Train_45.pdf" download class="cta-button">
        📄 Train 45 – Bluegrass Banjo Arrangement
      </a>
    </li>

    <li>
      <a
        href="https://drive.google.com/uc?export=download&id=1XE5ZI3v9HD0QOTQ6XdRjge8R8TojXEmV"
        class="cta-button"
        target="_blank"
        rel="noopener"
      >
        🎵 Train 45 – Mastering mp3
      </a>
    </li>
  </ul>

  <h2>Hinweise</h2>

  <ul>
    <li>Einmal gekauft – dauerhaft verfügbar</li>
    <li>Keine Abo-Falle</li>
    <li>Nur für dich persönlich lizenziert</li>
  </ul>

  <p>
    <a href="/kurse/musikbibliothek/" class="cta-button">
      Kurse zum selber lernen: Alle Lernmodule auf einen Blick
    </a>
  </p>
</BaseLayout>
