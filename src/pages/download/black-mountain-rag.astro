---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle = "Download: Black Mountain Rag";
const description = "Hier kannst du dein gekauftes Arrangement herunterladen.";
---

<BaseLayout pageTitle={pageTitle} 
  description={description} 
  ogType="article"
  bodyAttributes={{
    "data-product-id": "BMR-001"
  }}
>
  <h1>Dein Download</h1>

  <p>Danke für deinen Kauf! Hier kannst du dein Arrangement herunterladen.</p>

  <h2>Download</h2>

  <ul>
    <li>
      <a href="/downloads/Black_Mountain_Rag.pdf" download class="cta-button">
        📄 Black Mountain Rag – Bluegrass Banjo Arrangement
      </a>
    </li>

    <li>
      <a
        href="https://drive.google.com/uc?export=download&id=1ZxrwpBDpniwVYk-ADfDB-sx36OzaAkUN"
        class="cta-button"
        target="_blank"
        rel="noopener"
      >
        🎵 Black Mountain Rag – Backing Track (MP3)
      </a>
    </li>
  </ul>

  <h2>Hinweise</h2>

  <ul>
    <li>Einmal gekauft – dauerhaft verfügbar</li>
    <li>Keine Abo-Falle</li>
    <li>Nur für dich persönlich lizenziert</li>
  </ul>

  <p>
    <a href="/kurse/musikbibliothek/" class="cta-button">
      Kurse zum selber lernen: Alle Lernmodule auf einen Blick
    </a>
  </p>
</BaseLayout>