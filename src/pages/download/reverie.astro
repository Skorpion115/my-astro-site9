---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Download – Reverie L 68 – Piano Solo";
const description = "Download der Noten »Reverie«. Vielen Dank für Ihren Kauf.";
const keywords = "Arabesque No. 1, Piano Solo, Noten PDF";
const pageUrl = getPageUrl(Astro);
const downloads = [
  {
    label: "Reverie – Piano Solo (PDF)",
    url: "https://drive.google.com/uc?export=download&id=1c8x5uS-04SOMHMP5XIUKTr8zQHiHw4h8",
  },
];
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  noindex={true}
  bodyAttributes={{
    "data-product-id": "REV-001",
    "data-price": "5.95"
  }}
>
  <h1>Vielen Dank für deinen Kauf!</h1>

  <p>
    Du kannst deine <strong>Noten „Reverie – Piano Solo“</strong> jetzt
    herunterladen.
  </p>

  <p>
    👉 <strong>Wichtig:</strong> Bitte speichere die Datei direkt auf deinem Gerät
    ab.
  </p>

  <hr />
  <ul>
    {
      downloads.map((file) => (
        <li>
          <a href={file.url} download class="download-button">
            👉 {file.label}
          </a>
        </li>
      ))
    }
  </ul>

  <hr />

  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail:
    <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p class="vat-note">
    Rechnung mit auf Anfrage per E-Mail erhältlich.
  </p>

  <p>
    <a href="/kurse/musikbibliothek/" class="normal-links">← Zurück zur Musikbibliothek</a>
  </p>
  <script src="/scripts/purchase.js" defer></script>
</BaseLayout>