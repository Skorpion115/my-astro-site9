    <li>
      <a href="/downloads/Accordeon_Triste.pdf" download class="cta-button">
        📄 L'accordéon triste – Noten
      </a>
    </li>
    <li>
      <a
        href="https://drive.google.com/uc?export=download&id=1EXdv5njoxyPyRYDI9s40MBeRn1VFV7Sq"
        class="cta-button"
