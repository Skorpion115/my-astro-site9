---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle = "Download: Ruby – Kenny Rogers (Guitar Arrangement)";
const description = "Hier kannst du dein gekauftes Arrangement herunterladen.";
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  ogType="article"
  bodyAttributes={{
    "data-product-id": "RUBY-001",
    "data-price": "7.95"
  }}
>
  <h1>Dein Download</h1>

  <p>Danke für deinen Kauf! Hier kannst du dein Arrangement herunterladen.</p>

  <h2>Download</h2>

  <ul>
    <li>
      <a
        href="/notes/Ruby%20-%20Rhythmus%20Guitar.pdf" download
        class="cta-button"
      >
        📄 Ruby – Guitar I
      </a>
    </li>
    <li>
      <a
        href="https://drive.google.com/uc?export=download&id=1MTBpjWCk2GHm31lQ7nRw49AZe8TLVPUz"
        class="cta-button"
      >
        📄 Ruby – Komplettes Arrangement
      </a>
    </li>
  </ul>

  <h2>Hinweise</h2>

  <ul>
    <li>Einmal gekauft – dauerhaft verfügbar</li>
    <li>Keine Abo-Falle</li>
    <li>Nur für dich persönlich lizenziert</li>
  </ul>

  <script src="/scripts/purchase.js" defer></script>
</BaseLayout>
