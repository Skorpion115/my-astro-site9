---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Download: If I Never Sing Another Song – Jamie Cullum";
const description = "Download der Noten »If I Never Sing Another Song«. Vielen Dank für Ihren Kauf.";
const keywords = "If I Never Sing Another Song - Jamie Cullum, Klavier Solo, Noten PDF";
const pageUrl = getPageUrl(Astro);
const downloads = [
  {
    label: "If I Never Sing Another Song – Klavier Noten (PDF)",
    url: "https://drive.google.com/uc?export=download&id=1tc_CX9y1eFVCnlGN7UkJsJjnBOgGaZec",
  },
  {
    label: "If I Never Sing Another Song – Audio mp3",
    url: "https://drive.google.com/uc?export=download&id=1HvJqWrSg4fU8zTezJPvSQYK5rKy9MDt6",
  },
];
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  noindex={true}
  bodyAttributes={{
    "data-product-id": "IINSAS-001",
    "data-price": "5.95"
  }}
>
  <h1>Vielen Dank für deinen Kauf!</h1>

  <p>
    Du kannst deine <strong>Noten „If I Never Sing Another Song – Klavier Solo“</strong> jetzt
    herunterladen.
  </p>

  <p>
    👉 <strong>Wichtig:</strong> Bitte speichere die Datei direkt auf deinem Gerät
    ab.
  </p>

  <hr />
  <ul>
    {
      downloads.map((file) => (
        <li>
          <a href={file.url} download class="download-button">
            👉 {file.label}
          </a>
        </li>
      ))
    }
  </ul>

  <hr />

  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail:
    <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p class="vat-note">
    Rechnung mit auf Anfrage per E-Mail erhältlich.
  </p>

  <p>
    <a href="/kurse/musikbibliothek/" class="normal-links">← Zurück zur Musikbibliothek</a>
  </p>
  <script src="/scripts/purchase.js" defer></script>
</BaseLayout>