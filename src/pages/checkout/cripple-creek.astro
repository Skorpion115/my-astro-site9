---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Cripple Creek";
const heading = "Cripple Creek";
const description = "Sichere Zahlung für das Bluegrass-Banjo-Arrangement zu Cripple Creek. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Cripple Creek, Traditionell, Bluegrass Banjo, Banjo Arrangement, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/cripple-creek/";

// const imageSrc = "/bilder/Nancy_Rowland_Vorschau.jpg";
const imageAlt = "Cripple Creek – Vorschau";
const price = "2.50";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/cripple_creek_preview.png";

const contentHtml = `
  <br />
  <img
    src="/bilder/Cripple_Creek_Vorschau.png"
    alt="Cripple Creek Vorschau"
    class="product-image"
  >
  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/1mJ3TLElxlg_XVzNq8Th9VEzGI0DWtp5x/preview"
    width="60%"
    height="50"
  ></iframe>

  <p>
  <p>
  <a
    href="https://www.youtube.com/watch?v=WmYlSqvpUkw"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Cripple Creek ansehen"
    rel="noopener"
  >
    ▶️ Cripple Creek – Traditionell auf YouTube ansehen
  </a>
  </p>

  <p><strong>Digitales Produkt (PDF Download)</strong></p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Bluegrass Banjo Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>
    Perfekt für Banjo-Spieler, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Tabulaturblätter zum Song „Cripple Creek“</strong>.
  </p>
  <p>
    Banjo Tabs als PDF-Download.
  </p>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach dem Kauf steht der Download sofort zur Verfügung.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/banjo/" class="cta-button">
      Weitere Bluegrass Banjo-Stücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
  />
</BaseLayout>