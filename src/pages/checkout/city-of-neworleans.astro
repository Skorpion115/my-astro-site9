---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "City Of NewOrleans – Guitar Arrangement";
const heading = "City Of NewOrleans – Guitar Arrangement";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu City Of NewOrleans. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "City Of NewOrleans, Guitar Arrangement, Gitarren Tabs, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/city-of-neworleans/";
const productId = "CITY-001";
const imageSrc = "/bilder/City_Of_NewOrleans_Vorschau.png";
const imageAlt = "City Of NewOrleans – Vorschau";
const price = "5.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/city_of_neworleans_preview.png";

const contentHtml = `
  <br />
  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/1gpePJSakbeWxTVemqIbmCOMpOuFUh9oQ/preview"
    width="60%"
    height="50"
  ></iframe>

  <p>
  <p>
  <a
    href="https://www.youtube.com/watch?v=L70MSOuUiG0"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu City Of NewOrleans ansehen"
    rel="noopener"
  >
    ▶️ City Of NewOrleans – Arlo Guthrie auf YouTube ansehen
  </a>
  </p>

  <p><strong>Digitales Produkt (PDF Download)</strong></p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Gitarren Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>
    Perfekt für Gitarristen, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten- &amp; Tabulaturblätter zum Song „City Of NewOrleans“</strong>.
  </p>
  <p>
    Gitarren-Noten mit Akkorden und TABs + Gesangs- und Chornoten als PDF-Download. Das Stück ist schwierig dazu zu singen. Im Orginal spielt Arlo Guthrie eine Klavierbegleitung. Das was ich aufgeschrieben habe ist ein Studiomusiker gewesen. Das Stück ist in F#-Dur, also Capotaster auf dem 2. Bund setzen.
  </p>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach dem Kauf steht der Download sofort zur Verfügung.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/gitarre/" class="cta-button">
      Weitere Gitarrenstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    productId={productId}
    contentHtml={contentHtml}
  />
</BaseLayout>