---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "City Of NewOrleans – Arlo Guthrie (Guitar Arrangement)";
const heading = "City Of NewOrleans – Arlo Guthrie (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu City Of NewOrleans. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
