---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Hammond Flip – Organ Style (Klaus Wunderlich)";
const heading = "Hammond Flip – Organ Style (Klaus Wunderlich)";
const description = "Sichere Zahlung für das Keyboard-Arrangement zu Hammond Flip. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Hammond Flip, Organ Style, Klaus Wunderlich, Keyboard Arrangement, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/hammond-flip/";
const productId = "HF-001";
const imageSrc = "/bilder/Hammond_Flip_Vorschau.jpg";
const imageAlt = "Hammond Flip – Vorschau";
const price = "7.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/hammond_flip_preview.png";

const contentHtml = `
  <br />
  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/1t78ztmJQ1Qpx6NErVMyF7jJn0zm6cvoX/preview"
    width="60%"
    height="50"
  ></iframe>

  
  <p>
  <a
    href="https://www.youtube.com/watch?v=244HlpB3JoA"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Hammond Flip ansehen"
    rel="noopener"
  >
    ▶️ Hammond Flip – Klaus Wunderlich auf YouTube ansehen
  </a>
  </p>

  <p><strong>Digitales Produkt (PDF Download)</strong></p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Orgelnoten als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>
    Perfekt für Organisten, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten- &amp; Tabulaturblätter zum Song „Hammond Flip“</strong>.
  </p>
  <p>
    Orgel-Noten mit Akkorden als PDF-Download.
  </p>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach dem Kauf steht der Download sofort zur Verfügung.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/musikbibliothek/" class="cta-button">
      Weitere Musikstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    productId={productId}
    contentHtml={contentHtml}
  />
</BaseLayout>