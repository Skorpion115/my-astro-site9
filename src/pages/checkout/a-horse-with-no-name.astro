---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "A Horse With No Name – America (Guitar Arrangement)";
const heading = "A Horse With No Name – America (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu A Horse With No Name. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "A Horse With No Name, America, Guitar Arrangement, Gitarren Tabs, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/a-horse-with-no-name/";


const productId = "AHWNN-001";

// 👉 WICHTIG: echte eindeutige Transaktions-ID (nicht statisch!)
const transactionId = `TAT-${Date.now()}`;

const imageSrc = "/bilder/a_horse_with_no_name_vorschau.jpg";
const imageAlt = "A Horse With No Name – Vorschau";
const price = "7.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/a_horse_with_no_name_preview.png";

const contentHtml = `
  <br />
  <p>
  <a
    href="https://www.youtube.com/watch?v=2OTc4ZOsSSI"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu A Horse With No Name ansehen"
    rel="noopener"
  >
    ▶️ A Horse With No Name – America auf YouTube ansehen
  </a>
  </p>

  <p><strong>Digitales Produkt (PDF Download)</strong></p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Gitarren Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>
    Perfekt für Gitarristen, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten- &amp; Tabulaturblätter zum Song „A Horse With No Name“</strong>.
  </p>
  <p>
    Gitarren-Noten mit Akkorden und TABs + Gesangsnoten + Komplettes Arrangement als PDF-Download.
  </p>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach dem Kauf steht der Download sofort zur Verfügung.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/gitarre/" class="cta-button">
      Weitere Gitarrenstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    productId={productId}
    transactionId={transactionId}
    contentHtml={contentHtml}
  />
</BaseLayout>