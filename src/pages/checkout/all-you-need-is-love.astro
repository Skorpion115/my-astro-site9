---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "All You Need Is Love – Beatles (Guitar Arrangement)";
const heading = "All You Need Is Love – Beatles (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu All You Need Is Love. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "All You Need Is Love, Beatles, Guitar Arrangement, Gitarren Tabs, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/all-you-need-is-love/";
const productId = "AYNIL-001";
const imageSrc = "/bilder/all_you_need_is_love_vorschau.png";
const imageAlt = "All You Need Is Love Vorschau";
const price = "7.95";

const ogImage = "https://www.musicstudio-ziebart.de/bilder/all_you_need_is_love_preview.png"

const contentHtml = `
  <br />
  
  <p>
  <a
    href="https://www.youtube.com/watch?v=Z5-LRedkr3c"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu All You Need Is Love ansehen"
    rel="noopener"
  >
    ▶️ All You Need Is Love – Beatles auf YouTube ansehen
  </a>
  </p>
  <p><strong>Vollständig ausgearbeitetes Gitarren-Arrangement zum sofortigen Download.</strong></p>
  <p>Enthält alle wichtigen Stimmen: Guitar, Gesangsmelodie passend zur bekannten Aufnahme.</p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Gitarren Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>Kein vereinfachtes Tutorial, sondern eine vollständige, spielbare Transkription des Originals.</p>
  <ul>
    <li>Guitar Noten & Tabs</li>
    <li>Gesangsmelodie + Chor</li>
    <li>Gitarrensolo</li>
    <li>Bass Noten</li>
    <li>Lead Sheet</li>
  </ul>
  <p>
    Dieses Arrangement ist ein vollständiges, spielbares Gesamtwerk des Songs.
    Ideal zum Üben, Spielen im Unterricht oder als Band Arrangment. Man kann den Song auch alleine mit einer akustischen Gitarre gut spielen.
  </p>
  <p>
    Keine vereinfachte Lernversion, sondern ein ausführlich ausgearbeitetes Arrangement für Gitarristen.
  </p>

  <ul>
    <li>Sofortiger Download nach Zahlung</li>
    <li>PDF-Dateien</li>
    <li>Kein Versand physischer Produkte</li>
    <li>Einmaliger Kauf, keine Abo-Kosten</li>
  </ul>
  
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/musikbibliothek/" class="cta-button">
      Weitere Gitarrenstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    productId={productId}
    contentHtml={contentHtml}
  />
</BaseLayout>