---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Shame – Robbie Williams & Gary Barlow (Guitar Arrangement)";
const heading = "Shame – Robbie Williams & Gary Barlow (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu Shame. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Shame, Robbie Williams, Gary Barlow, Guitar Arrangement, Gitarren Tabs, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/shame/";
const productId = "SHAME-001";
const price = "7.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/shame_preview.png";

const contentHtml = `
  <br />

  <p class="pdf-download">
    <a
      href="https://drive.google.com/file/d/1oi4gH2kvk54ezRS1bUwfY-3drwNWgwDO/preview"
      target="_blank"
      rel="noopener noreferrer"
    >
      ⬇ Noten Vorschau
    </a>
  </p>


  <p>
  <a
    href="https://www.youtube.com/watch?v=tv49bC5xGVY"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Shame ansehen"
    rel="noopener"
  >
    ▶️ Shame – Robbie Williams & Gary Barlow auf YouTube ansehen
  </a>
  </p>

  <p><strong>Originalgetreues, vollständig ausgearbeitetes Song-Arrangement zum sofortigen Download.</strong></p>
  <p>Enthält alle wichtigen Stimmen: Steel-Guitar, Gesangsmelodie + Choir, Strings, Bass und Drums – exakt auf das Original abgestimmt.</p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Gitarren Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>Kein vereinfachtes Tutorial, sondern eine vollständige, spielbare Transkription des Originals.</p>
  <ul>
    <li>Steel-Guitar Noten & Tabs</li>
    <li>Gesangsnoten + Text + Choir</li>
    <li>Strings Noten</li>
    <li>Bass Noten & Tabs</li>
    <li>Bongo Noten</li>
    <li>Drums Noten</li>
    <li>Full Score (Gesamtpartitur)</li>

  </ul>
  <p>
    Dieses Arrangement ist ein vollständiges, spielbares Gesamtwerk des Songs.
    Ideal zum Üben, Spielen im Unterricht oder für Band-Arrangements.
  </p>
  <p>
    Keine vereinfachten Internet-Tabs – dieses Arrangement ist vollständig ausgearbeitet und originalgetreu transkribiert.
  </p>

  <ul>
    <li>Sofortiger Download nach Zahlung</li>
    <li>PDF-Dateien</li>
    <li>Kein Versand physischer Produkte</li>
    <li>Einmaliger Kauf, keine Abo-Kosten</li>
  </ul>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/e-gitarre/" class="cta-button">
      Weitere Gitarrenstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    price={price}
    productId={productId}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
  />
</BaseLayout>