---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "In The Year 2525 – Zager & Evans (Guitar Arrangement)";
const heading = "In The Year 2525 – Zager & Evans (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu In The Year 2525. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "In The Year 2525, Zager & Evans, Guitar Arrangement, Gitarren Tabs, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/in-the-year-2525/";


const productId = "ITY-001";

// 👉 WICHTIG: echte eindeutige Transaktions-ID (nicht statisch!)
// const transactionId = `TAT-${Date.now()}`;

const imageSrc = "/bilder/in_the_year_2525_vorschau.png";
const imageAlt = "In The Year 2525 – Vorschau";
const price = "7.95";

const ogImage = "https://www.musicstudio-ziebart.de/bilder/in_the_year_2525_preview.png";

const contentHtml = `
  <br />
  <p>
    Zur Orientierung kannst du dir den Originalsong anhören:
  </p>
  <p>
  <a
    href="https://www.youtube.com/watch?v=Gb7poHQuMWg"
