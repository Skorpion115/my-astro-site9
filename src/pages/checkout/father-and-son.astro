---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Father And Son – Cat Stevens (Guitar Arrangement)";
const heading = "Father And Son – Cat Stevens (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu Father And Son. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Behind Blue Eyes, Limp Bizkit, Guitar Arrangement, Gitarren Tabs, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/father-and-son/";


const productId = "FAS-001";

// 👉 WICHTIG: echte eindeutige Transaktions-ID (nicht statisch!)
// const transactionId = `TAT-${Date.now()}`;

const imageSrc = "/bilder/father_and_son_vorschau.png";
const imageAlt = "Father And Son – Vorschau";
const price = "8.95";

const ogImage = "https://www.musicstudio-ziebart.de/bilder/father_and_son_preview.png";

const contentHtml = `
  <br />
  <p>
    Zur Orientierung kannst du dir den Originalsong anhören:
  </p>
  <p>
  <a
    href="https://www.youtube.com/watch?v=P6zaCV4niKk"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu More Than Words ansehen"
    rel="noopener"
  >
    ▶️ Father And Son – Cat Stevens auf YouTube ansehen
  </a>
  </p>

  <p><strong>Digitales Produkt (PDF Download)</strong></p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Gitarren Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>
    Perfekt für Gitarristen, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten- &amp; Tabulaturblätter zum Song „Father And Son“</strong>.
  </p>
  <p>
    Gitarren-Noten mit Akkorden und TABs + Gesangsnoten + komplette Arrangment als PDF-Download.
  </p>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach dem Kauf steht der Download sofort zur Verfügung.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/gitarre/" class="cta-button">
      Weitere Gitarrenstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    productId={productId}
    contentHtml={contentHtml}
  />
</BaseLayout>