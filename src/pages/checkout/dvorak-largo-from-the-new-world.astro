---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Antonín Dvořák - Largo from Symphony No. 9 'From the New World' – Piano Solo";
const heading = "Antonín Dvořák - Largo from Symphony No. 9 'From the New World'";
const description = "Sichere Zahlung für das Piano-Solo von Antonín Dvořák. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Antonín Dvořák, Largo, Symphony No. 9, From the New World, Piano, Solo, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/dvorak-largo-from-the-new-world/";
const productId = "LARGO-001";
// const imageSrc = "/bilder/dvorak_aus_der_neuen_welt_largo_vorschau.png";
const imageAlt = "Antonín Dvořák - Largo from Symphony No. 9 'From the New World' – Vorschau";
const price = "5.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/largo_preview.png";

const contentHtml = `
  <br />
  <img
    src="/bilder/Largo_Vorschau.png"
    alt="Largo – Vorschau"
    class="product-image"
  />
  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/1pJepIFMXiLfmynzJQefV6mGy4rekv-gm/preview"
    width="60%"
    height="50"
  ></iframe>

  <p>
  <p>
  <a
    href="https://www.youtube.com/watch?v=ytcQ-I1BTNk"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Largo ansehen"
    rel="noopener"
  >
    ▶️ Largo – Dvořák auf YouTube ansehen
  </a>
  </p>

  <p><strong>Digitales Produkt (PDF Download)</strong></p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Jazz Gitarren Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>
    Perfekt für Banjo-Picker, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten zu der 9. Sinfonie „Largo“</strong>.
  </p>
  <p>
    Piano  Noten und Mastering mp3 für das Arrangement als PDF Download.
  </p>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach dem Kauf steht der Download sofort zur Verfügung.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/musikbibliothek/" class="cta-button">
      Weitere Musikstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
    productId={productId}
  />
</BaseLayout>