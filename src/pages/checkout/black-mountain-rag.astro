---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Black Mountain Rag";
const heading = "Black Mountain Rag";
const description = "Sichere Zahlung für das Bluegrass-Banjo-Arrangement zu Black Mountain Rag. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Black Mountain Rag, Traditionell, Bluegrass Banjo, Banjo Arrangement, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/black-mountain-rag/";
const productId = "BMR-001";
// const imageSrc = "/bilder/Nancy_Rowland_Vorschau.jpg";
const imageAlt = "Black Mountain Rag – Vorschau";
const price = "2.50";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/black_mountain_rag_preview.png";

const contentHtml = `
  <br />
  <img
    src="/bilder/Black_Mountain_Rag_Vorschau.png"
    alt="Black Mountain Rag Vorschau"
    class="product-image"
  />
  <p>
  <a
    href="https://www.youtube.com/watch?v=44O9ZSf7Dhc"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Black Mountain Rag ansehen"
    rel="noopener"
  >
    ▶️ Black Mountain Rag auf YouTube ansehen
  </a>
  </p>

  <p><strong>Originalgetreues, vollständig ausgearbeitetes Song-Arrangement zum sofortigen Download.</strong></p>
  <p>Enthält alle wichtigen Stimmen: Banjo Solo – exakt auf das Original abgestimmt.</p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Gitarren Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>Kein vereinfachtes Tutorial, sondern eine vollständige, spielbare Transkription des Originals.</p>
  <ul>
    <li>Black Mountain Rag Banjo Solo Tabs</li>
    <li>Backing Track</li>
  </ul>
  <p>
    Dieses Arrangement ist ein vollständiges, spielbares Gesamtwerk des Songs.
    Ideal zum Üben, Spielen im Unterricht oder für Band-Arrangements.
  </p>
  <p>
    Keine vereinfachten Internet-Tabs – dieses Arrangement ist vollständig ausgearbeitet und originalgetreu transkribiert.
  </p>

  <ul>
    <li>Sofortiger Download nach Zahlung</li>
    <li>PDF-Dateien</li>
    <li>Kein Versand physischer Produkte</li>
    <li>Einmaliger Kauf, keine Abo-Kosten</li>
  </ul>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/banjo/" class="cta-button">
      Weitere Bluegrass Banjo-Stücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    productId={productId}
    contentHtml={contentHtml}
  />
</BaseLayout>