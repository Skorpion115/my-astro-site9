---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Chopin – Nocturne in E-flat Major, Op. 9 No. 2 Piano Sheet Music PDF";
const heading = "Chopin – Nocturne in E-flat Major, Op. 9 No. 2";
const description = "Sichere Zahlung für das Piano-Solo von Chopin. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Chopin, Nocturne, E-flat Major, Op. 9 No. 2, Piano Sheet Music PDF";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/chopin-nocturne-op-9-no-2/";
const productId = "NOCTU-001";
// const imageSrc = "/bilder/dvorak_aus_der_neuen_welt_largo_vorschau.png";
const imageAlt = "Frédéric Chopin – Nocturne in E-flat Major, Op. 9 No. 2 – Vorschau";
const price = "5.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/nocturne_opus_9_preview.png";

const contentHtml = `
  <br />

  <embed
    src="/bilder/nocturne-no-9-vorschau.pdf"
    type="application/pdf"
    width="100%"
    height="600px"
  />
  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/14Hx_9XBP4k8P506c0gTK3FwIj8SInqcp/preview"
    width="60%"
    height="50"
  ></iframe>

  <p>
  <p>
  <a
    href="https://www.youtube.com/watch?v=yDSxPiFOrEY&t"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Largo ansehen"
    rel="noopener"
  >
    ▶️ Nocturne Opus 9 No. 2 – Chopin auf YouTube ansehen
  </a>
  </p>

  <p><strong>Digitales Produkt (PDF Download)</strong></p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Piano Noten als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>
    Perfekt für Klavierspieler, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten zu „Nocturne Opus 9 No. 2“</strong>.
  </p>
  <p>
    Piano  Noten und Mastering mp3 für das Arrangement als PDF Download.
  </p>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach dem Kauf steht der Download sofort zur Verfügung.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/musikbibliothek/" class="cta-button">
      Weitere Musikstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    productId={productId}
    heading={heading}
    description={description}
    keywords={keywords}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
  />
</BaseLayout>