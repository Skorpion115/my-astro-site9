---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Behind Blue Eyes – Limp Bizkit (Guitar Arrangement)";
const heading = "Behind Blue Eyes – Limp Bizkit (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu Behind Blue Eyes. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Behind Blue Eyes, Limp Bizkit, Guitar Arrangement, Gitarren Tabs, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/behind-blue-eyes/";


const productId = "BE-001";

// 👉 WICHTIG: echte eindeutige Transaktions-ID (nicht statisch!)
// const transactionId = `TAT-${Date.now()}`;

const imageSrc = "/bilder/behind_blue_eyes_vorschau.png";
const imageAlt = "Behind Blue Eyes – Vorschau";
const price = "6.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/behind_blue_eyes_preview.png";

const contentHtml = `
  <br />
  <p>
    Zur Orientierung kannst du dir den Originalsong anhören:
  </p>
  <p>
  <a
    href="https://www.youtube.com/watch?v=-0RQU0LyJqg"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Behind Blue Eyes ansehen"
    rel="noopener"
  >
    ▶️ Behind Blue Eyes – Limp Bizkit auf YouTube ansehen
  </a>
  </p>

  <p><strong>Digitales Produkt (PDF Download)</strong></p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Gitarren Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>
    Perfekt für Gitarristen, die den Song lernen möchten!
  </p>
  <p>
    Sichere dir meine
    <strong>eigenen Noten- &amp; Tabulaturblätter zum Song „Behind Blue Eyes“</strong>.
  </p>
  <p>
    Gitarren-Noten mit Akkorden und TABs + Gesangsnoten + Lead Sheet als PDF-Download.
  </p>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Nach dem Kauf steht der Download sofort zur Verfügung.
  </p>
  <p>
    <strong>Sofortiger Download:</strong> Alle Dateien stehen dir direkt nach dem Kauf als PDF zur Verfügung.
  </p>
  <p>
    <strong>Digitale Lieferung:</strong> Es erfolgt kein Versand von physischen Produkten.
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/gitarre/" class="cta-button">
      Weitere Gitarrenstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    productId={productId}
    contentHtml={contentHtml}
  />
</BaseLayout>