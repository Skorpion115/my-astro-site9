---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Mad World – Gary Jules";
const heading = "Mad World – Gary Jules";
const description = "Sichere Zahlung für das Stück Mad World. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Mad World - Gary Jules, Piano, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/mad-world/";
const productId = "MW-001";
const imageSrc = "/bilder/mad_world_vorschau.png";
const imageAlt = "/bilder/mad_world_vorschau.png";
const price = "5.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/mad_world_preview.png";

const contentHtml = `
  <br />
  
  <p>
  <a
    href="https://www.youtube.com/watch?v=etSbOs3aUqI"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Mad World ansehen"
    rel="noopener"
  >
    ▶️ Mad World – Gary Jules auf YouTube ansehen
  </a>
  </p>
  <p><strong>Vollständig ausgearbeitetes Piano-Arrangement zum sofortigen Download.</strong></p>
  <p>Enthält Piano Solo passend zur bekannten Aufnahme.</p>

  <p>Kein vereinfachtes Tutorial, sondern eine vollständige, spielbare Transkription des Originals.</p>
  <ul>
    <li>Piano Noten</li>
    <li>Gesang + Text</li>
  </ul>
  <p>
    Dieses Arrangement ist ein vollständiges, spielbares Gesamtwerk des Songs.
    Ideal zum Üben, Spielen im Unterricht.
  </p>
  <p>
    Keine vereinfachte Lernversion, sondern ein ausführlich ausgearbeitetes Arrangement für Pianisten.
  </p>
  
  <ul>
    <li>Sofortiger Download nach Zahlung</li>
    <li>PDF-Dateien</li>
    <li>Kein Versand physischer Produkte</li>
    <li>Einmaliger Kauf, keine Abo-Kosten</li>
  </ul>
  
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/musikbibliothek/" class="cta-button">
      Weitere Musikstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
    productId={productId}
  />
</BaseLayout>