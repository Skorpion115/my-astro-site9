---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Heart Of Gold – Neil Young (Guitar Arrangement)";
const heading = "Heart Of Gold – Neil Young (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu Heart Of Gold. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Heart Of Gold, Neil Young, Guitar Arrangement, Gitarren Tabs, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/heart-of-gold/";


const productId = "HOG-001";

// 👉 WICHTIG: echte eindeutige Transaktions-ID (nicht statisch!)
// const transactionId = `TAT-${Date.now()}`;

const imageSrc = "/bilder/heart_of_gold_vorschau.png";
const imageAlt = "Heart Of Gold – Vorschau";
const price = "7.95";

const ogImage = "https://www.musicstudio-ziebart.de/bilder/heart_of_gold_preview.png";

const contentHtml = `
  <br />
  <p>
    Zur Orientierung kannst du dir den Originalsong anhören:
  </p>
  <p>
  <a
    href="https://www.youtube.com/watch?v=c7eB7Wns1-M"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Where Do You Go To My Lovely ansehen"
    rel="noopener"
  >
    ▶️ Heart Of Gold – Neil Young auf YouTube ansehen
  </a>
  </p>

  <p><strong>Vollständig ausgearbeitetes Gitarren-Arrangement zum sofortigen Download.</strong></p>
  <p>Enthält alle wichtigen Stimmen: Guitar I, Guitar II, Bass, Gesangsmelodie und Solo passend zur bekannten Aufnahme.</p>

  <p>
    Keine vereinfachte Lernversion, sondern ein ausführlich ausgearbeitetes Arrangement für Gitarristen.
  </p>
  <ul>
    <li>Guitar Noten & Tabs</li>
    <li>Gesangsmelodie + Text</li>
    <li>Mundharmonika Solos</li>
    <li>Bassline</li>
    <li>Drums Noten</li>
    <li>Full Score (Gesamtpartitur)</li>
  </ul>
  <p>
    Dieses Arrangement ist ein vollständiges, spielbares Gesamtwerk des Songs.
    Ideal zum Üben, Spielen im Unterricht oder für Band-Arrangements.
  </p>
  
  <ul>
    <li>Sofortiger Download nach Zahlung</li>
    <li>PDF-Dateien</li>
    <li>Kein Versand physischer Produkte</li>
    <li>Einmaliger Kauf, keine Abo-Kosten</li>
  </ul>
  
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/gitarre/" class="cta-button">
      Weitere Gitarrenstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    productId={productId}
    contentHtml={contentHtml}
  />
</BaseLayout>