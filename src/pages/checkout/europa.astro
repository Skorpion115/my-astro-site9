---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Europa – Carlos Santana (Guitar Arrangement)";
const heading = "Europa – Carlos Santana (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu Europa. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Europa , Carlos Santana, Guitar Arrangement, Gitarren Tabs, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/europa/";
const productId = "EUR-001";
const imageSrc = "/bilder/europa_santana_vorschau.png";
const imageAlt = "Europa Vorschau";
const price = "9.95";
const ogImage = "https://www.musicstudio-ziebart.de/bilder/europa_santana_preview.webp"

const contentHtml = `
  <br />
  
  <p>
  <a
    href="https://www.youtube.com/watch?v=Ot6pSrKT1oc"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Ten Words ansehen"
    rel="noopener"
  >
    ▶️ Europa – Carlos Santana auf YouTube ansehen
  </a>
  </p>
  <p><strong>Vollständig ausgearbeitetes Gitarren-Arrangement zum sofortigen Download.</strong></p>
  <p>Enthält alle wichtigen Stimmen: Guitar, Gesangsmelodie passend zur bekannten Aufnahme.</p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Gitarren Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>Kein vereinfachtes Tutorial, sondern eine vollständige, spielbare Transkription des Originals.</p>
  <ul>
    <li>Guitar Noten & Tabs</li>
    <li>Orgelnoten</li>
    <li>Bassline</li>
    <li>Drums Noten</li>
    <li>Backing Track</li>
    <li>Mastering</li>
  </ul>
  <p>
    Dieses Arrangement ist ein vollständiges, spielbares Gesamtwerk des Songs.
    Ideal zum Üben, Spielen im Unterricht oder für Band-Arrangements.
  </p>
  <p>
    Keine vereinfachte Lernversion, sondern ein ausführlich ausgearbeitetes Arrangement für Gitarristen.
  </p>

  <ul>
    <li>Sofortiger Download nach Zahlung</li>
    <li>PDF-Dateien</li>
    <li>Kein Versand physischer Produkte</li>
    <li>Einmaliger Kauf, keine Abo-Kosten</li>
  </ul>
  
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/e-gitarre/" class="cta-button">
      Weitere Gitarrenstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    productId={productId}
    contentHtml={contentHtml}
  />
</BaseLayout>