      Weitere Gitarrenstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    price={price}
    productId={productId}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
  />
</BaseLayout>