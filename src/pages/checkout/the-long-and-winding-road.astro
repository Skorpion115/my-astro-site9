---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "The Long And Winding Road – Beatles";
const heading = "The Long And Winding Road – Beatles";
const description = "Sichere Zahlung für das Stück The Long And Winding Road. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "The Long And Winding Road - Beatles, Piano, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/the-long-and-winding-road/";
const productId = "TLAWR-001";
const imageSrc = "/bilder/the_long_and_winding_road_vorschau.png";
const imageAlt = "/bilder/the_long_and_winding_road_vorschau.png";
const price = "7.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/the_long_and_winding_road_preview.png";

const contentHtml = `
  <br />
  
  <p>
  <a
    href="https://www.youtube.com/watch?v=yDP3dwpoVTo"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu The Long And Winding Road ansehen"
    rel="noopener"
  >
    ▶️ The Long And Winding Road – Beatles auf YouTube ansehen
  </a>
  </p>
  <p><strong>Vollständig ausgearbeitetes Piano-Arrangement zum sofortigen Download.</strong></p>
  <p>Enthält Piano Begleitung passend zur bekannten Aufnahme.</p>

  <p>Kein vereinfachtes Tutorial, sondern eine vollständige, spielbare Transkription des Originals.</p>
  <ul>
    <li>Piano Noten</li>
    <li>Gesang</li>
    <li>Strings</li>
    <li>French Horns</li>
    <li>Bassnoten</li>
    <li>Drums Noten</li>
    <li>Backing Track</li>
  </ul>
  <p>
    Dieses Arrangement ist ein vollständiges, spielbares Gesamtwerk des Songs.
    Ideal zum Üben, Spielen im Unterricht oder als Band Arrangement nutzbar.
  </p>
  <p>
    Keine vereinfachte Lernversion, sondern ein ausführlich ausgearbeitetes Arrangement für Pianisten.
  </p>
  
  <ul>
    <li>Sofortiger Download nach Zahlung</li>
    <li>PDF-Dateien</li>
    <li>Kein Versand physischer Produkte</li>
    <li>Einmaliger Kauf, keine Abo-Kosten</li>
  </ul>
  
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/musikbibliothek/" class="cta-button">
      Weitere Musikstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
    productId={productId}
  />
</BaseLayout>