---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Where Do You Go To My Lovely – Peter Sarstedt (Guitar Arrangement)";
const heading = "Where Do You Go To My Lovely – Peter Sarstedt (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu Where Do You Go To My Lovely. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
