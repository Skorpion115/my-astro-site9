---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "I'll Be Back – The Beatles (Guitar Arrangement)";
const heading = "I'll Be Back – The Beatles (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu I'll Be Back. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "I'll Be Back - The Beatles, Guitar Arrangement, Gitarren Tabs, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/i'll-be-back/";
const productId = "IBB-001";
const imageSrc = "/bilder/i'll_be_back_vorschau.png";
const imageAlt = "I'll Be Back – Vorschau";
const price = "7.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/i'll_be_back_preview.png";

const contentHtml = `
  <br />
  <p>
  <a
    href="https://www.youtube.com/watch?v=4jKahlEKo0Q"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu I'll Be Back ansehen"
    rel="noopener"
  >
    ▶️ I'll Be Back – The Beatles auf YouTube ansehen
  </a>
  </p>

  <p><strong>Originalgetreues, vollständig ausgearbeitetes Song-Arrangement zum sofortigen Download.</strong></p>
  <p>Enthält alle wichtigen Stimmen: SteelGuitar, Nylon Guitar,Gesangsmelodie – exakt auf das Original abgestimmt.</p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Gitarren Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>Kein vereinfachtes Tutorial, sondern eine vollständige, spielbare Transkription des Originals.</p>
  <ul>
    <li>Steel Guitar Noten & Tabs</li>
    <li>Nylon Guitar Noten & Tabs</li>
    <li>Gesangsnoten + Text + 2. Stimme</li>
    <li>Bassline</li>
    <li>Drums Noten</li>
    <li>Lead Sheet</li>
    <li>Full Score (Gesamtpartitur)</li>

  </ul>
  <p>
    Dieses Arrangement ist ein vollständiges, spielbares Gesamtwerk des Songs.
    Ideal zum Üben, Spielen im Unterricht oder für Band-Arrangements.
  </p>
  <p>
    Keine vereinfachten Internet-Tabs – dieses Arrangement ist vollständig ausgearbeitet und originalgetreu transkribiert.
  </p>

  <ul>
    <li>Sofortiger Download nach Zahlung</li>
    <li>PDF-Dateien</li>
    <li>Kein Versand physischer Produkte</li>
    <li>Einmaliger Kauf, keine Abo-Kosten</li>
  </ul>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/gitarre/" class="cta-button">
      Weitere Gitarrenstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    productId={productId}
    contentHtml={contentHtml}
  />
</BaseLayout>