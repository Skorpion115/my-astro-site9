---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Here Comes The Sun – George Harrison (Guitar Arrangement)";
const heading = "Here Comes The Sun – George Harrison (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu Here Comes The Sun. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
