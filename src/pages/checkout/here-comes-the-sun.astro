const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/here-comes-the-sun/";
const productId = "HCTS-001";
const imageSrc = "/bilder/here_comes_the_sun_vorschau.png";
const imageAlt = "Here Comes The Sun – Vorschau";
const price = "5.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/here_comes_the_sun_preview.png";

const contentHtml = `
  <br />
  <p>
  <a
