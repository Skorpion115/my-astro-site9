---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "My Heart Will Goes On – Celine Dion";
const heading = "My Heart Will Goes On – Celine Dion";
const description = "Sichere Zahlung für das Stück My Heart Will Goes On. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "My Heart Will Goes On - Celine Dion, Piano, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/my-heart-will-goes-on/";
const productId = "MHWGO-001";
const imageSrc = "/bilder/my_heart_will_goes_on_vorschau.png";
const imageAlt = "My Heart Will Goes On – Notenbild";
const price = "5.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/my-heart-will-goes-on_preview.png";

const contentHtml = `
  <br />
  <p>
  <a
    href="https://www.youtube.com/watch?v=9bFHsd3o1w0"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu My Heart Will Goes On ansehen"
    rel="noopener"
  >
    ▶️ My Heart Will Goes On – Celine Dion auf YouTube ansehen
  </a>
  </p>
  
  <p><strong>Originalgetreues, vollständig ausgearbeitetes Song-Arrangement zum sofortigen Download.</strong></p>
  <p>Enthält Piano Begleitung – exakt auf das Original abgestimmt.</p>

  <p>Kein vereinfachtes Tutorial, sondern eine vollständige, spielbare Transkription des Originals.</p>
  <ul>
    <li>Piano Noten</li>
    <li>Noten für Altflöte</li>
    <li>Noten für Flöte</li>
    <li>Pedalisierung</li>
  </ul>
  <p>
    Dieses Arrangement ist ein vollständiges, spielbares Gesamtwerk des Songs.
    Ideal zum Üben, Spielen im Unterricht oder als Band Arrangement nutzbar.
  </p>
  <p>
    Keine vereinfachten Internet-Noten – dieses Arrangement ist vollständig ausgearbeitet und originalgetreu transkribiert.
  </p>
  
  <ul>
    <li>Sofortiger Download nach Zahlung</li>
    <li>PDF-Dateien</li>
    <li>Kein Versand physischer Produkte</li>
    <li>Einmaliger Kauf, keine Abo-Kosten</li>
  </ul>
  
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/musikbibliothek/" class="cta-button">
      Weitere Musikstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
    productId={productId}
  />
</BaseLayout>