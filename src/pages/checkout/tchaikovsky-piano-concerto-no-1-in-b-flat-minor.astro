const imageAlt = "Pyotr Ilyich Tchaikovsky – Piano Concerto No. 1 in B-flat Minor – Vorschau";
const price = "5.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/tschaikowsky_klavierkonzert_nr_1_klaviernoten_download_preview.png";

const contentHtml = `
