---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Across The Universe – The Beatles (Guitar Arrangement)";
const heading = "Across The Universe – The Beatles (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu Across The Universe. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Across The Universe, The Beatles, Guitar Arrangement, Gitarren Tabs, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/across-the-universe/";
const productId = "ATU-001";
const price = "5.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/across_the_universe_preview.png";

const contentHtml = `
  <br />

  <p class="pdf-download">
    <a
      href="https://drive.google.com/file/d/1b90WurONuWqphjnd246Eq8l2Y-bRRZr2/preview"
      target="_blank"
      rel="noopener noreferrer"
    >
      ⬇ Noten Vorschau
    </a>
  </p>


  <p>
  <a
    href="https://www.youtube.com/watch?v=jfVOmE1yoRo"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Across The Universe ansehen"
    rel="noopener"
  >
    ▶️ Across The Universe – The Beatles auf YouTube ansehen
  </a>
  </p>

  <p><strong>Vollständig ausgearbeitetes Gitarren-Arrangement zum sofortigen Download.</strong></p>

  <p>Enthält ausgearbeitete Parts für Steel Guitar, Gesangsmelodie und Bass, passend zur bekannten Aufnahme.</p>

  <p>Das Arrangement ist für Gitarristen gedacht, die den bekannten Song möglichst nah am Originalstil spielen möchten. Es enthält eine detailliert ausgearbeitete Gitarrenfassung mit Tabs und Spielhinweisen.</p>

  <p>Du erhältst sofort nach Kauf Zugriff auf die Gitarren Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>
    Keine vereinfachte Lernversion, sondern ein ausführlich ausgearbeitetes Arrangement für Gitarristen.
  </p>
  <ul>
    <li>Steel Guitar Noten & Tabs</li>
    <li>Gesangsnoten als Orientierung</li>
    <li>Bass Noten & Tabs</li>

  </ul>
  <p>
    Dieses Arrangement ist ein vollständiges, spielbares Gesamtwerk des Songs.
    Ideal zum Üben, Spielen im Unterricht oder für Band-Arrangements.
  </p>
  
  <p>Dieses Arrangement bietet eine vollständig ausgearbeitete, spielbare Gitarrenfassung des Songs. Ideal zum Üben oder Spielen im Unterricht.</p>

  <ul>
    <li>Sofortiger Download nach Zahlung</li>
    <li>PDF-Dateien</li>
    <li>Kein Versand physischer Produkte</li>
    <li>Einmaliger Kauf, keine Abo-Kosten</li>
  </ul>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/e-gitarre/" class="cta-button">
      Weitere Gitarrenstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    price={price}
    productId={productId}
    returnUrl={returnUrl}
    contentHtml={contentHtml}
  />
</BaseLayout>