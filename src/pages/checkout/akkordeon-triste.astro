---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "L'accordéon triste – Sergio Castelli";
const heading = "L'accordéon triste – Sergio Castelli";
const description = "Sichere Zahlung für das Akkordeon-Arrangement zu L'accordéon triste. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
