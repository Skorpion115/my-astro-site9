const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/akkordeon-triste/";
const productId = "AKKTR-001";

const imageSrc = "/bilder/Akkordeon_Triste_Vorschau.jpg";
const imageAlt = "L'accordéon triste Vorschau";
const price = "5.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/akkordeon_triste_preview.png"

const contentHtml = `
  <br />
  <p>
    <strong>🎧 Hörprobe:</strong><br />
    Audioaufnahme aus dem enthaltenen Arrangement.
  </p>

  <iframe
    src="https://drive.google.com/file/d/1EXdv5njoxyPyRYDI9s40MBeRn1VFV7Sq/preview"
    width="60%"
    height="50"
  ></iframe>
  <p>
  <a
    href="https://www.youtube.com/watch?v=Eo5gEGD5t40"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu L'accordéon triste ansehen"
    rel="noopener"
  >
    ▶️ L'accordéon triste – Sergio Castelli auf YouTube ansehen
  </a>
  </p>

  <p><strong>Originalgetreues, vollständig ausgearbeitetes Song-Arrangement zum sofortigen Download.</strong></p>
  <p>Enthält alle wichtigen Stimmen: Orgel Solo – exakt auf das Original abgestimmt.</p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Akkordeonnoten als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>Kein vereinfachtes Tutorial, sondern eine vollständige, spielbare Transkription des Originals.</p>
  <ul>
    <li>Akkordeon Noten</li>
    <li>Mastering</li>
  </ul>
  <p>
    Dieses Arrangement ist ein vollständiges, spielbares Gesamtwerk des Songs.
    Ideal zum Üben oder Spielen im Unterricht.
  </p>
  <p>
    Keine vereinfachten Internet-Tabs – dieses Arrangement ist vollständig ausgearbeitet und originalgetreu transkribiert.
  </p>

  <ul>
    <li>Sofortiger Download nach Zahlung</li>
    <li>PDF-Dateien</li>
    <li>Kein Versand physischer Produkte</li>
    <li>Einmaliger Kauf, keine Abo-Kosten</li>
  </ul>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/musikbibliothek/" class="cta-button">
      Weitere Musikstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    productId={productId}
    contentHtml={contentHtml}
  />
</BaseLayout>