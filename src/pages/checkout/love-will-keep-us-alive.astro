---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Love Will Keep Us Alive – Eagles (Guitar Arrangement)";
const heading = "Love Will Keep Us Alive – Eagles (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu Love Will Keep Us Alive. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Love Will Keep Us Alive - Eagles, Guitar Arrangement, Gitarren Tabs, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/love-will-keep-us-alive/";
const productId = "LWKUA-001";
const imageSrc = "/bilder/love_will_keep_us_alive_vorschau.png";
const imageAlt = "Love Will Keep Us Alive Vorschau";
const price = "7.95";

const ogImage = "https://www.musicstudio-ziebart.de/bilder/love_will_keep_us_alive_preview.png"

const contentHtml = `
  <br />
  
  <p>
  <a
    href="https://www.youtube.com/watch?v=4-kF-wgTHfo"
    class="normal-links"
    target="_blank"
