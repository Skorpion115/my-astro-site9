---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductPage from "../../components/ProductPage.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Now And Forever – Richard Marx (Guitar Arrangement)";
const heading = "Now And Forever – Richard Marx (Guitar Arrangement)";
const description = "Sichere Zahlung für das Gitarren-Arrangement zu Now And Forever. Nach erfolgreicher Zahlung erhältst du sofort Zugriff auf den Download.";
const keywords = "Now And forever, Richard Marx, Guitar Arrangement, Gitarren Tabs, PDF Download";
const pageUrl = getPageUrl(Astro);
const returnUrl = "https://www.musicstudio-ziebart.de/download/now-and-forever/";


const productId = "NAF-001";

// 👉 WICHTIG: echte eindeutige Transaktions-ID (nicht statisch!)
// const transactionId = `TAT-${Date.now()}`;

const imageSrc = "/bilder/now_and_forever_vorschau.png";
const imageAlt = "Now And Forever – Vorschau";
const price = "5.95";

//Open-Graph-Bild für diese Produktseite.
// Wird von Google, Social Media und Merchant Center
// als Hauptbild für Vorschau und Produktdarstellung verwendet.
const ogImage = "https://www.musicstudio-ziebart.de/bilder/now_and_forever_preview.png";

const contentHtml = `
  <br />
  <p>
    Zur Orientierung kannst du dir den Originalsong anhören:
  </p>
  <p>
  <a
    href="https://www.youtube.com/watch?v=OeDiK2uy3DU"
    class="normal-links"
    target="_blank"
    aria-label="YouTube Video zu Behind Blue Eyes ansehen"
    rel="noopener"
  >
    ▶️ Now And Forever – Richard Marx auf YouTube ansehen
  </a>
  </p>

  <p><strong>Vollständig ausgearbeitetes Gitarren-Arrangement zum sofortigen Download.</strong></p>
  <p>Enthält alle wichtigen Stimmen: Guitar, Gesangsmelodie passend zur bekannten Aufnahme.</p>
  <p>Du erhältst sofort nach Kauf Zugriff auf die Gitarren Tabs als PDF-Datei.</p>
  <p>Kein Versand physischer Produkte.</p>

  <p>
    Keine vereinfachte Lernversion, sondern ein ausführlich ausgearbeitetes Arrangement für Gitarristen.
  </p>
  <ul>
    <li>Steel Guitar Noten & Tabs</li>
    <li>Gesangsnoten + Text</li>
  </ul>
  <p>
    Dieses Arrangement ist ein vollständiges, spielbares Gesamtwerk des Songs.
    Ideal zum Üben, Spielen im Unterricht oder für Band-Arrangements.
  </p>

  <ul>
    <li>Sofortiger Download nach Zahlung</li>
    <li>PDF-Dateien</li>
    <li>Kein Versand physischer Produkte</li>
    <li>Einmaliger Kauf, keine Abo-Kosten</li>
  </ul>
  <p class="small">
    Preis: <strong>${price.replace(".", ",")}&nbsp;€</strong> (gemäß § 19 UStG umsatzsteuerfrei)
  </p>
  
  <p>
    Bei PayPal-Problemen auf dem iPhone bitte die Seite im normalen Safari-Browser öffnen.
  </p>
  <p>
    Falls es Probleme mit dem Download gibt, schreib mir bitte eine kurze
    E-Mail: <br />
    <strong>postmaster@musicstudio-ziebart.de</strong>
  </p>

  <p>
    <a href="/kurse/gitarre/" class="cta-button">
      Weitere Gitarrenstücke entdecken
    </a>
  </p>
`;
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogImage={ogImage}
  ogType="product"
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <ProductPage
    heading={heading}
    description={description}
    keywords={keywords}
    imageSrc={imageSrc}
    imageAlt={imageAlt}
    price={price}
    returnUrl={returnUrl}
    productId={productId}
    contentHtml={contentHtml}
  />
</BaseLayout>