---
import BaseLayout from "../layouts/BaseLayout.astro";
import YouTube from "../components/YouTube.astro";
import "../styles/lite-yt-embed.css";
const pageTitle =
  "Gitarre Videoanleitungen – Bossa Dorado, Like Ice In the Sunshine, Yesterday & City of New Orleans";
const description =
  "Lerne Gitarre spielen mit kostenlosen Videoanleitungen: Bossa Dorado von Dorado Schmitt, Like Ice In The Sunshine von Hanno Harders, Yesterday von den Beatles und City of New Orleans von Arlo Guthrie.";
const keywords =
  "gitarre tutorial, bossa dorado gitarre, like ice in the sunshine gitarre, yesterday gitarre lernen, city of new orleans gitarre arlo guthrie";
const SITE_URL =
  import.meta.env.SITE_URL || "https://www.musicstudio-ziebart.de";
const pageUrl = `${SITE_URL}/gitarre-videoanleitung/`;

// RDFa-Markup für das Video nur auf dieser Seite
// Video-Daten

const videoData = [
  {
    loc: `${SITE_URL}/gitarrenunterricht/`,
    title: "🎸 Bossa Dorado Guitar Lesson – Gypsy Jazz Solo & Rhythm (Dorado Schmitt)",
    description:
      "Willkommen zu meinem Gitarren-Tutorial zu “Bossa Dorado” von Dorado Schmitt! In diesem Video zeige ich dir Schritt für Schritt, wie du den Song auf der Konzertgitarre spielen kannst. Ich habe nur das Hauptthema aufgeschrieben. Das andere wäre zu komplex. Es gehört in die Stilrichtung Gypsy Jazz, die von Django Reinhardt geprägt wurde.",
    contentLoc: "https://www.youtube.com/embed/LYOEuto28l8",
    thumbnailLoc: "https://i.ytimg.com/vi/LYOEuto28l8/hqdefault.jpg",
    publicationDate: "2026-05-05T17:00:00+02:00",
    duration: "PT14M38S",
  },
  {
    loc: `${SITE_URL}/gitarrenunterricht/`,
    title: "Silence Is Golden – The Tremeloes – Guitar Lesson (Gitarren-Tutorial)",
    description:
      "Willkommen zu meinem Gitarren-Tutorial zu “Silence Is Golden” von The Tremeloes! In diesem Video zeige ich dir Schritt für Schritt, wie du den Song auf der Akustikgitarre spielen kannst.",
    contentLoc: "https://www.youtube.com/embed/OxBca9ZfFv8",
    thumbnailLoc: "https://i.ytimg.com/vi/OxBca9ZfFv8/hqdefault.jpg",
    publicationDate: "2025-11-25T14:23:00+02:00",
    duration: "PT12M19S",
  },
  {
    loc: `${SITE_URL}/gitarrenunterricht/`,
    title: "🎸 The Lion Sleeps Tonight – The Tokens - Gitarren-Tutorial (einfach erklärt)",
    description:
      "Lerne den bekannten Song 'The Lion Sleeps Tonight' Schritt für Schritt auf der Gitarre! 🎶 In diesem Gitarren-Tutorial zeige ich dir alle Akkorde, Schlagmuster und Rhythmusvarianten, damit du den Song allein auf der Gitarre spielen kannst – ohne Playback oder Begleitung. Ich spiele den Song zunächst mit meinem eigenen Playback vor, damit du hörst, wie er komplett klingt, und erkläre danach alle Teile einzeln, damit du ihn selbst spielen kannst. 🎧 Hinweis: Das Playback wird nur für die Demonstration verwendet – du lernst den Song so, dass du ihn komplett allein auf der Gitarre spielen kannst.",
    contentLoc: "https://www.youtube.com/embed/eFcGadGwenQ",
    thumbnailLoc: "https://i.ytimg.com/vi/eFcGadGwenQ/hqdefault.jpg",
    publicationDate: "2025-10-29T14:09:00+02:00",
    duration: "PT12M55S",
  },
  {
    loc: `${SITE_URL}/gitarrenunterricht/`,
    title: "Like Ice In The Sunshine – Beagle Music – Guitar Lesson (Gitarren-Tutorial)",
    description:
      "In diesem Video zeige ich dir, wie du Like Ice In The Sunshine auf der Gitarre spielen kannst. Du lernst Schritt für Schritt die Akkorde, den Rhythmus und den Schlag. Ideal für Anfänger, Fortgeschrittente und alle, die diesen bekannten Popsong auf der Akustikgitarre spielen möchten.",
    contentLoc: "https://www.youtube.com/embed/Jk6ECVwJyZk",
    thumbnailLoc: "https://i.ytimg.com/vi/Jk6ECVwJyZk/hqdefault.jpg",
    publicationDate: "2025-08-30T14:23:00+02:00",
    duration: "PT13M12S",
  },
  {
    loc: `${SITE_URL}/gitarrenunterricht/`,
    title: "Beatles – Yesterday | Gitarre Tutorial 🎸",
    description:
      "Lernvideo und Gitarren Tutorial für das Gitarrenstück 'Yesterday von den Beatles'. Dieses Stück kann man wunderbar alleine spielen, also ohne Bass, Drums usw. Die Gitarre wird in einer Double Flatstimmung umgestimmt.",
    contentLoc: "https://www.youtube.com/embed/Jla_18ar1aE",
    thumbnailLoc: "https://i.ytimg.com/vi/Jla_18ar1aE/hqdefault.jpg",
    publicationDate: "2025-09-10T14:00:00+02:00",
    duration: "PT12M40S",
  },
  {
    loc: `${SITE_URL}/gitarrenunterricht/`,
    title: "Catch The Wind – Donovan | Gitarren Tutorial",
    description:
      "🎸 Lerne „Catch The Wind“ von Donovan auf der Gitarre – Schritt für Schritt erklärt! In diesem Gitarren-Tutorial spiele ich dir den Song komplett vor – begleitet von einem selbst erstellten Playback. Danach erkläre ich dir alle Akkorde, Schlagmuster und die Struktur, damit du den Song selbst begleiten kannst. 📌 Die Version basiert auf der Aufnahme von Donovan aus dem Jahr 1965 – ich habe sie nach Gehör herausgearbeitet. ✅ Inhalt: • Komplettes Vorspiel mit Playback • Einfache Akkorde & Schlagmuster • Songabschnitte verständlich erklärt",
    contentLoc: "https://www.youtube.com/embed/ifJuoPeWBU8",
    thumbnailLoc: "https://i.ytimg.com/vi/ifJuoPeWBU8/hqdefault.jpg",
    publicationDate: "2025-09-16T14:00:00+02:00",
    duration: "PT24M44S",
  },
];
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  keywords={keywords}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  twitterTitle={pageTitle}
  twitterDescription={description}
  twitterUrl={pageUrl}
>
  <br />
  <section>
    <h2>Gitarre Videoanleitung</h2>
    <p>
      Lerne 5 berühmte Klassiker auf der Gitarre:
      <strong>Bossa Dorado</strong>, 
      <strong>Silence Is Golden</strong>, 
      <strong>The Lion Sleeps Tonight</strong>, 
      <strong>Catch The Wind</strong>,
      <strong>Yesterday</strong> und <strong>City of New Orleans</strong>. Die
      Tutorials sind ideal für Anfänger und fortgeschrittene Gitarristen.
    </p>
    <!-- RDFa-Markup Struktur für das VideoObject -->
    {
      videoData.map((video) => (
        <div vocab="http://schema.org/" typeof="VideoObject">
          <meta property="name" content={video.title} />
          <meta property="description" content={video.description} />
          <meta property="thumbnailUrl" content={video.thumbnailLoc} />
          <meta property="uploadDate" content={video.publicationDate} />
          <meta property="duration" content={video.duration} />
          <meta property="embedUrl" content={video.contentLoc} />

          <div class="video-container-wrapper">
            <div class="video-container">
              <lite-youtube
                videoid={video.contentLoc.split("/").pop()}
                style={"background-image: url('" + video.thumbnailLoc + "');"}
              >
                <a
                  href={video.contentLoc}
                  class="lty-playbtn"
                  title={video.title}
                >
                  <span class="lyt-visually-hidden">
                    Play Video: {video.title}
                  </span>
                </a>
              </lite-youtube>
            </div>
            <h2>{video.title}</h2>
            <p>{video.description}</p>
          </div>
        </div>
      ))
    }
  </section>
  <p>
    <a
      href="/gitarrenunterricht/"
      class="normal-links"
      aria-label="Zurück zu Gitarrenunterricht"
    >
      Zurück zu Gitarrenunterricht
    </a>
  </p>
  <YouTube />
</BaseLayout>
