---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Cripple Creek – Traditionell";
const description = "Bluegrass 3-Fingerstyle von Cripple Creek für fortgeschrittene Anfänger.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>
    Mit diesem Strück hatte Earl Scruggs im zarten Alter von 9 Jahren einen ersten Preis gewonnen. Er wußte das das Schiedsrichter Team das Stück gefiel. Deswegen hatte er den Preis gewonnen.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Bluegrass 3-Fingerstyle</li>
    <li>Rhythmisch anspruchsvoll</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für Anfänger, die ihre ersten Stücke im Bluegrass-Stil lernen wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/cripple-creek/" class="cta-button">
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>