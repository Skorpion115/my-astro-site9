---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Achille Claude Debussy - Arabesque No. 1 Piano Solo";
const description =
  "Piano Solo Arabesque No. 1 für fortgeschrittene Anfänger.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>
    Dieses Stück hat Achille Claude Debussy in jungem Alter komponiert. Es ist ein schönes Beispiel für den Impressionismus in der Musik.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Piano Noten</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>Für fortgeschrittene Anfänger.</p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a
      href="/checkout/arabesque-nr-1/"
      class="cta-button"
    >
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>
