---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Come Together – Beatles (Guitar Arrangement)";
const description =
  "All You Need Is Love - Beatles Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält Begleitung, Gitarrensolos und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>Original gespielt von den Beatles</p>

  <p>
    Dieses Arrangement vermittelt typische Rhythmus-Techniken. Es wird mit E-Gitarren gespielt.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Guitar I</li>
    <li>Rhythmische Begleitung</li>
    <li>Mit Gesangs + Text</li>
    <li>Gitarrensolo</li>
    <li>E-Piano</li>
    <li>Bass Noten</li>
    <li>Drums Noten</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Spieler, die ihren Rhythmus verbessern
    wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/come-together/" class="cta-button">
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>