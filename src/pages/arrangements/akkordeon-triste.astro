---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "L'accordéon triste – Akkordeon Arrangement";
const description = "Akkordeon-Arrangement im Stil von Sergio Castelli für fortgeschrittene Anfänger. Enthält französische Mussette Walzer.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>

  <p>Original gespielt von Sergio Castelli</p>

  <p>
    Dieses Arrangement enthält noch eine zweite Stimme, die die Melodie mit Harmonien ergänzt. Es ist im Stil von französischen Musette Walzern gehalten.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Akkordeon Noten</li>
    <li>Performance auf YouTube</li>
    <li>Mastering mp3</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Rhythmus verbessern wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
<p>
    <a href="/checkout/akkordeon-triste/" class="cta-button">
        Jetzt kaufen / herunterladen
    </a>  
</p>


</BaseLayout>