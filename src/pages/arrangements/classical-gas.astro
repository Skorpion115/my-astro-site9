---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Classical Gas – Mason Williams";
const description =
  "Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält typische Strumming-Patterns und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <section>

  <p>
    Dieses Arrangement basiert auf klassische Musik. Es wird nur mit Noten aufgeschrieben. Es sind keine Tabs dabei so wie es in der klassischen Musik üblich ist. Tabulaturen brauchen viel zu viel Platz. Das Stück wird im Orginal mit Orchester gespielt.
  </p>

  <p class="info-box">
    Du erhältst ein vollständiges PDF mit Noten und Fingersätzen.  
    Ein Video-Tutorial ist aktuell nicht enthalten.
  </p>

</section>

<hr>

<section>

  <h2>Lernziel</h2>
  <ul>
    <li>Sicheres Spielen von einem klassischen Thema</li>
    <li>Rhythmusgefühl und Akkordwechsel verbessern</li>
  </ul>

</section>

<section>

  <h2>Spieltechnik</h2>
  <ul>
    <li>Zerlegt Akkorde und Melodie gleichzeitig spielen</li>
    <li>Dynamisches Spiel (leise / laut)</li>
    <li>gleichmäßiger Groove im 4/4 Takt</li>
  </ul>

</section>

<hr>

<section>

  <h2>Inhalt</h2>
  <ul>
    <li>PDF Noten</li>
    <li>Komplette Songstruktur</li>
  </ul>

</section>

<section class="cta">

  <a href="/checkout/classical-gas/" class="cta-button">
    Jetzt herunterladen
  </a>

</section>
</BaseLayout>