---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Hey Jude - The Beatles";
const description =
  "Hey Jude für fortgeschrittene Anfänger.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>
    Dieses Stück ist in der Orginaltonart Eb Dur geschrieben. Die Gesangsstimme liegt oben drüber.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Klaviernoten</li>
    <li>Gesangsstimme + Text + Choir</li>
    <li>Guitar Noten</li>
    <li>Bass</li>
    <li>Drums Noten</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>Für fortgeschrittene Anfänger.</p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a
      href="/checkout/hey-jude/"
      class="cta-button"
    >
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>