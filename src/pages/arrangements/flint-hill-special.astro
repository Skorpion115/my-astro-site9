---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Flint Hill Special – Earl Scruggs";
const description = "Banjo-Arrangement im Stil von Earl Scruggs für fortgeschrittene Anfänger.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>

  <p>Original gespielt von Earl Scruggs</p>

  <p>
    Dieses Stück wird min einem D-Tuner gespielt. Die h Saite kann man dann einen Ganzton zum a runter drehen und die g Saite einen Halbton zum fis. Das macht dann diesen berühmten Banjo Sound aus.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Melodiespiel</li>
    <li>3-Fingerstyle</li>
    <li>Praxisnahes Spielgefühl</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Rhythmus verbessern wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
<p>
    <a href="/checkout/flint-hill-special/" class="cta-button">
        Jetzt kaufen / herunterladen
    </a>  
</p>


</BaseLayout>