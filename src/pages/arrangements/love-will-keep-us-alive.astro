---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Love Will Keep Us Alive – Eagles (Guitar Arrangement)";
const description =
  "Love Will Keep Us Alive - Eagles Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält Begleitung, Gitarrensolos und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>Original gespielt von den Eagles</p>

  <p>
    Dieses Arrangement vermittelt typische Rhythmus-Techniken. Es wird mit E-Gitarren gespielt.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>E-Guitar Tabs</li>
    <li>Rhythmische Begleitung</li>
    <li>Mit Gesang + Text + Chor</li>
    <li>Gitarren Solo</li>
    <li>Bass Noten</li>
    <li>Drums Noten</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Spieler, die ihren Rhythmus verbessern
    wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/love-will-keep-us-alive/" class="cta-button">
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>