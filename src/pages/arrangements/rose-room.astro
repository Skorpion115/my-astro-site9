---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Rose Room – Charlie Christian Gitarren Solo";
const description =
  "Jazz Guitar Solo im Stil von Charlie Christian für fortgeschrittene Anfänger.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>Original gespielt von Charlie Christian</p>

  <p>
    Dieses Stück ist einer meiner Lieblings Solos von Charlie Christian.
    Es wird sehr schnell gespielt, aber es lohnt sich, das zu lernen.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Melodiespiel</li>
    <li>Jazz Guitar Solo</li>
    <li>Praxisnahes Spielgefühl</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Rhythmus verbessern
    wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/rose-room/" class="cta-button">
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>
