---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Intermezzo – Organ Style (Klaus Wunderlich)";
const description = "Orgel-Arrangement im Stil von Klaus Wunderlich für Fortgeschrittene.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>Eigenkomposition</p>

  <p>
    Dieses Arrangement ist eine eigene Komposition im Stil von Klaus Wunderlich.
    <br />
    Fingersätze sind im PDF enthalten, damit du das Stück gut lernen kannst.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Melodiespiel mit interessanten Begleitung</li>
    <li>Praxisnahes Spielgefühl</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>Für fortgeschrittene Spieler, die ihren Horizont erweitern wollen.</p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/intermezzo/" class="cta-button">
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>
