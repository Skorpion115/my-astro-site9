---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Ludwig van Beethoven - Für Elise Piano Solo";
const description =
  "Piano Solo im Stil von Antonín Dvořák für fortgeschrittene Anfänger.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>
    Dieses Stück hat Ludwig van Beethoven für seine große Liebe Therese Malfatti
    geschrieben. Sie war die Tochter seines Hausarztes.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Melodiespiel</li>
    <li>Piano Solo</li>
    <li>Praxisnahes Spielgefühl</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>Für fortgeschrittene Anfänger.</p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a
      href="/checkout/beethoven-fur-elise/"
      class="cta-button"
    >
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>
