---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Like Ice In The Sunshine – Guitar Arrangement";
const description =
  "Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält typische Strumming-Patterns und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>Original gespielt von Beagle Music</p>

  <p>
    Dieses Arrangement vermittelt typische Rhythmus-Techniken mit Down- und
    Upstroke-Patterns.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Strumming Patterns</li>
    <li>Rhythmische Begleitung</li>
    <li>Mit Gesangs und Chornoten</li>
    <li>Bass und Drumnoten</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Rhythmus verbessern
    wollen. Man kann den Song auch ganz alleine mit der Gitarre spielen, da die Noten auch Gesangs- und Chornoten enthalten.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/like-ice-in-the-sunshine/" class="cta-button">
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>
