---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "The Night They Drove Old Dixie Down – Joan Baez Gitarren-Arrangement";
const description =
  "Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält typische Strumming-Patterns und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>Original gespielt von Joan Baez</p>

  <p>
    Dieses Arrangement vermittelt typische Rhythmus Begleitung mit Strumming-Techniken.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Steel Guitar</li>
    <li>Mit Gesangsnoten + Text</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Rhythmus verbessern
    wollen. Man kann den Song auch ganz alleine mit der Gitarre spielen, da die Noten auch Gesangsnoten enthalten. Joan Baez spielte es mit Band aber auch alleine ohne Band. Die Begleitung ist also auch für Solo-Spieler geeignet.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/the-night-they-drove-old-dixie-down/" class="cta-button">
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>