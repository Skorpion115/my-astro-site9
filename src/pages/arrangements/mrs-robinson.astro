---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Mrs. Robinson – Simon & Garfunkel Gitarren-Arrangement";
const description =
  "Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält typische Strumming-Patterns und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>Original gespielt von Simon & Garfunkel</p>

  <p>
    Dieses Arrangement vermittelt typische Rhythmus Begleitung für Fingerpicking.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Steel Guitar</li>
    <li>Mit Gesangsnoten + Text + 2. Stimme</li>
    <li>Bassnoten</li>
    <li>Lead Sheet</li>
    <li>Backing Track</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Rhythmus verbessern
    wollen. Man kann den Song auch ganz alleine mit der Gitarre spielen, da die Noten auch Gesangsnoten enthalten.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/mrs-robinson/" class="cta-button">
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>