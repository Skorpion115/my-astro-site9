---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Hey There Delilah – Guitar Arrangement";
const description =
  "Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält typische Finger Picking-Techniken und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>Original gespielt von Plain White T's</p>

  <p>
    Dieses Arrangement vermittelt eine einfache Akkordzerlegung.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Akkordzerlegung Technik</li>
    <li>Rhythmische Begleitung</li>
    <li>Mit Gesangsnoten</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Rhythmus verbessern
    wollen. Man kann den Song auch ganz alleine mit der Gitarre spielen, da die Noten auch Gesangsnoten enthalten.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/hey-there-delilah/" class="cta-button">
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>
