---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Frédéric Chopin - Nocturne in E-flat Major, Op. 9 No. 2 Piano Sheet Music PDF";
const description =
  "Piano Solo Nocturne in E-flat Major, Op. 9 No. 2 für fortgeschrittene Anfänger.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>
    Dieses Stück hat Frédéric Chopin im Jahr 1830 komponiert und ist eines seiner bekanntesten Werke. Es ist ein wunderschönes und emotionales Stück, das oft von Pianisten gespielt wird. Es ist in einem langsamen Tempo geschrieben und zeichnet sich durch seine lyrische Melodie und seinen sanften Charakter aus.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Melodiespiel</li>
    <li>Piano Solo</li>
    <li>Genaue Pedalisierung</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>Für fortgeschrittene Klavierspieler.</p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a
      href="/checkout/chopin-nocturne-op-9-no-2/"
      class="cta-button"
    >
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>