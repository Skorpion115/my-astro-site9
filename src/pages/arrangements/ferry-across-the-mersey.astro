---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Ferry Across the Mersey – Gerry & The Pacemakers";
const description =
  "Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält typische Strumming-Patterns und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <section>
    <p>Orginal gespielt von Gerry & The Pacemakers</p>

    <p>
      Dieses Arrangement basiert auf Struming Patterns. Es in Noten und Patterns
      aufgeschrieben.
    </p>

    <p class="info-box">
      Du erhältst ein vollständiges PDF mit Noten, Tabs und Fingersätzen. Ein
      Video-Tutorial ist aktuell nicht enthalten.
    </p>
  </section>

  <hr />

  <section>
    <h2>Lernziel</h2>
    <ul>
      <li>Sicheres Spielen mit Auf und Abschlag</li>
      <li>Rhythmusgefühl und Akkordwechsel verbessern</li>
    </ul>
  </section>

  <section>
    <h2>Spieltechnik</h2>
    <ul>
      <li>Strumming Pattern</li>
      <li>Dynamisches Spiel (leise / laut)</li>
      <li>gleichmäßiger Groove im 4/4 Takt</li>
    </ul>
  </section>

  <hr />

  <section>
    <h2>Inhalt</h2>
    <ul>
      <li>PDF Noten & Tabs</li>
      <li>Komplette Songstruktur</li>
      <li>Gesangsnoten</li>
    </ul>
  </section>

  <section class="cta">
    <a href="/checkout/ferry-across-the-mersey/" class="cta-button">
      Jetzt herunterladen
    </a>
  </section>
</BaseLayout>
