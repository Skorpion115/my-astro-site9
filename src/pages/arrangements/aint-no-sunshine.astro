---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Ain't No Sunshine – Bill Withers (Guitar Arrangement)";
const description =
  "Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält typische Strumming-Patterns und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>

  <p>Original gesungen von Bill Withers</p>

  <p>
     Ain't No Sunshine" ist ein Klassiker der Soul- und R&B-Musik. Bill Withers schrieb den Song in nur 30 Minuten, inspiriert von einer persönlichen Erfahrung. Dieses Arrangement bietet eine authentische Umsetzung des Songs für Gitarristen, die ihre Fähigkeiten im Strumming und in der Begleitung verbessern möchten. Mit diesem Arrangement können Musiker die charakteristischen Elemente des Songs erlernen und spielen.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Nylon Guitar Noten & Tabs</li>
    <li>Gesangsnoten + Text</li>
    <li>E-Guitar Noten & Tabs</li>
    <li>Bass Noten & Tabs</li>
    <li>Drums Noten</li>
    <li>Lead Sheet</li>
    <li>Backing Track</li>
    <li>Full Score (Gesamtpartitur)</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Rhythmus verbessern wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/aint-no-sunshine/" class="cta-button">
        Jetzt kaufen / herunterladen
    </a>  
  </p>

</BaseLayout>