---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Harvest Moon – Neil Young (Guitar Arrangement)";
const description =
  "Harvest Moon - Neil Young Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält Begleitung, Gitarrensolos und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>Original gespielt von Neil Young</p>

  <p>
    Dieses Arrangement vermittelt typische Rhythmus-Techniken. Es wird mit einer Westerngitarre gespielt.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Steel Guitar Tabs</li>
    <li>Nylon Guitar Tabs</li>
    <li>Mit Gesang + Text + Chor</li>
    <li>Mundharmonika Solo</li>
    <li>Bass Noten</li>
    <li>Brush Drums Noten</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Spieler, die ihren Rhythmus verbessern
    wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/harvest-moon/" class="cta-button">
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>