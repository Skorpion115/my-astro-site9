---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "What A Wonderful World – Louis Armstrong";
const description = "Jazz Guitar Melodic Style von Louis Armstrong für fortgeschrittene Anfänger.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>Original gespielt von Louis Armstrong.</p>

  <p>
    Dieses Stück ist sehr langsam. Man kann es gut lernen, um das Melodiespiel zu üben.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Melodic Style</li>
    <li>Jazz Guitar</li>
    <li>Praxisnahes Spielgefühl</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Rhythmus verbessern
    wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/what-a-wonderful-world/" class="cta-button">
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>
