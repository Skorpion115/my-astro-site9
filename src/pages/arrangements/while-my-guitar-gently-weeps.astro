---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "While My Guitar Gently Weeps – George Harrison (Arrangement für Gitarre)";
const description =
  "Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält typische Strumming-Patterns und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <section>

  <p>
    Dieses Arrangement basiert auf der originalen Version von George Harrison.
    Du lernst die Begleitung mit Fokus auf Rhythmus und Akkordspiel, basierend auf einem typischen Strumming-Pattern im 4/4 Takt.
  </p>

  <p class="info-box">
    Du erhältst ein vollständiges PDF mit Noten, Tabs und Spielhinweisen.  
    Ein Video-Tutorial ist aktuell nicht enthalten.
  </p>

</section>

<hr>

<section>

  <h2>Lernziel</h2>
  <ul>
    <li>Sicheres Spielen eines modernen Pop-Strumming-Patterns</li>
    <li>Rhythmusgefühl und Akkordwechsel verbessern</li>
  </ul>

</section>

<section>

  <h2>Spieltechnik</h2>
  <ul>
    <li>Down- und Upstroke Strumming</li>
    <li>Dynamisches Spiel (leise / laut)</li>
    <li>gleichmäßiger Groove im 4/4 Takt</li>
  </ul>

</section>

<section>

  <h2>Originalsong</h2>

  <p>
    Zur Orientierung kannst du dir den Originalsong anhören:
  </p>

  <a href="https://www.youtube.com/watch?v=-fWLuSPen_g" class="normal-links" target="_blank" rel="noopener">
    ▶ While My Guitar Gently Weeps – George Harrison (Original Video)
  </a>

</section>

<hr>

<section>

  <h2>Inhalt</h2>
  <ul>
    <li>Rhythmus Gitarre Pattern</li>
    <li>Zusätzliche Grifftabellen</li>
    <li>E-Gitarren Noten</li>
    <li>Gesangsnoten + Text + 2. Stimme</li>
    <li>Bass Noten</li>
    <li>Drums Noten</li>
  </ul>

</section>

<section class="cta">

  <a href="/checkout/while-my-guitar-gently-weeps/" class="cta-button">
    Jetzt herunterladen
  </a>

</section>
</BaseLayout>