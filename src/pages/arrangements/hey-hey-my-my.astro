---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Hey Hey My My – Neil Young (Guitar Arrangement)";
const description =
  "Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält typische Strumming-Patterns und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>

  <p>Original gesungen von Neil Young</p>

  <p>
        Hey Hey My My ist ein Klassiker des Rock-Musik. Neil Young schrieb den Song in den späten 1970er Jahren. Das Stück ist auf dem Album "Out Of The Blue" erschienen und wurde zu einem der bekanntesten Songs des Künstlers.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>SteelGuitar Noten & Pattern</li>
    <li>Gesangsnoten + Text</li>
    <li>Mundharmonika Solo</li>
    <li>Lead Sheet</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Rhythmus verbessern wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/hey-hey-my-my/" class="cta-button">
        Jetzt kaufen / herunterladen
    </a>  
  </p>

</BaseLayout>