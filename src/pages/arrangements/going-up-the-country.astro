---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Going Up The Country – Canned Heat (Guitar Arrangement)";
const description =
  "Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält typische Strumming-Patterns und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>

  <p>Original gesungen von Canned Heat</p>

  <p>
     Going Up The Country" ist ein Klassiker des Blues-Rock. Canned Heat schrieb den Song in den späten 1960er Jahren, inspiriert von traditionellen Blues-Elementen. Dieses Arrangement bietet eine authentische Umsetzung des Songs für Gitarristen, die ihre Fähigkeiten im Strumming und in der Begleitung verbessern möchten. Mit diesem Arrangement können Musiker die charakteristischen Elemente des Songs erlernen und spielen.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>E-Guitar Noten & Tabs</li>
    <li>Gesangsnoten + Text</li>
    <li>Querflöten Noten</li>
    <li>Bass Noten & Tabs</li>
    <li>Drums Noten</li>
    <li>Full Score (Gesamtpartitur)</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Rhythmus verbessern wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/going-up-the-country/" class="cta-button">
        Jetzt kaufen / herunterladen
    </a>  
  </p>

</BaseLayout>