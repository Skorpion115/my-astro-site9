---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Bossa Dorado – Dorado Schmitt Gitarren Solo";
const description =
  "Jazz Guitar Solo im Stil von Dorado Schmitt für fortgeschrittene Anfänger.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>Original gespielt von Dorado Schmitt</p>

  <p>
    Dieses Stück ist einer meiner Lieblings Solos von Dorado Schmitt. Es ist ein Duett. Die Rhythmus Gitarre ist auch dabei.Die Stilrichtung ist Gypsy Jazz, früher als Zigeuner Jazz bezeichnet. Einfach mal reinhören, es lohnt sich.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Melodiespiel</li>
    <li>Jazz Guitar Solo</li>
    <li>Praxisnahes Spielgefühl</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Rhythmus verbessern
    wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/bossa-dorado/" class="cta-button">
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>