---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Lullaby In Blue – Organ Style (Klaus Wunderlich)";
const description = "Orgel-Arrangement im Stil von Klaus Wunderlich für fortgeschrittene Anfänger. Enthält typische Samba Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>

  <p>Original gespielt von Klaus Wunderlich</p>

  <p>
    Dieses Arrangement vermittelt wie man Akkorde in der weiten Lage spielen kann, um ein volles Klangbild zu erzeugen.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Vierstimmiges Melodiespiel</li>
    <li>Praxisnahes Spielgefühl</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Horizont erweitern wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
<p>
    <a href="/checkout/lullaby-in-blue/" class="cta-button">
        Jetzt kaufen / herunterladen
    </a>  
</p>


</BaseLayout>