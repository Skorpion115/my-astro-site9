---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "Black Mountain Rag";
const description = "Bluegrass 3-Fingerstyle von Black Mountain Rag für fortgeschrittene Anfänger.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>
  <p>
    Black Mountain Rag ist ein Bluegrass-Klassiker, der im 3-Fingerstyle gespielt wird. Es ist ein tolles Stück für fortgeschrittene Anfänger, die ihre Fähigkeiten im Bluegrass-Stil verbessern möchten. Den Rhytmus zu halten macht den meisten Schülern am meisten Probleme, aber mit viel Übung wirst du das meistern und eine Menge Spaß dabei haben! Am besten mit dem Fuß mitwippen, um den Groove zu fühlen.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Bluegrass 3-Fingerstyle</li>
    <li>Rhythmisch anspruchsvoll</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger, die ihre ersten Stücke im Bluegrass-Stil lernen wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/black-mountain-rag/" class="cta-button">
      Jetzt kaufen / herunterladen
    </a>
  </p>
</BaseLayout>