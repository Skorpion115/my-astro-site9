---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageUrl } from "../../utils/getPageUrl.js";

const pageTitle = "I Take A Lot Of Pride In What I Am – Merle Haggard (Guitar Arrangement)";
const description =
  "Gitarren-Arrangement für fortgeschrittene Anfänger. Enthält typische Strumming-Patterns und praxisnahe Begleitung.";
const pageUrl = getPageUrl(Astro);
---

<BaseLayout
  pageTitle={pageTitle}
  description={description}
  href={pageUrl}
  ogTitle={pageTitle}
  ogDescription={description}
  ogUrl={pageUrl}
  ogType="product"
>

  <p>Original gesungen von Merle Haggard</p>

  <p>
     I Take A Lot Of Pride In What I Am" ist ein Klassiker des Country-Musik. Merle Haggard schrieb den Song in den späten 1960er Jahren. Dieses Arrangement bietet eine authentische Umsetzung des Songs für Gitarristen, die ihre Fähigkeiten im Strumming und in der Begleitung verbessern möchten. Mit diesem Arrangement können Musiker die charakteristischen Elemente des Songs erlernen und spielen.
  </p>

  <h2>Inhalt</h2>

  <ul>
    <li>Steel Guitar Noten & Tabs</li>
    <li>Gesangsnoten + Text</li>
    <li>Banjo Tabs</li>
    <li>Bass Noten & Tabs</li>
    <li>Drums Noten</li>
    <li>Full Score (Gesamtpartitur)</li>
  </ul>

  <h2>Für wen ist das geeignet?</h2>

  <p>
    Für fortgeschrittene Anfänger und Spieler, die ihren Rhythmus verbessern wollen.
  </p>

  <h2>Jetzt lernen</h2>

  <p>
    Hier kannst du das komplette Arrangement herunterladen und sofort spielen.
  </p>

  <!-- Platzhalter für später: Download / Kauf -->
  <p>
    <a href="/checkout/i-take-a-lot-of-pride/" class="cta-button">
        Jetzt kaufen / herunterladen
    </a>  
  </p>

</BaseLayout>