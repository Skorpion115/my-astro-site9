<script is:inline>
  const input = document.getElementById("songSearch");
  const items = document.querySelectorAll("#songList li");
  const noResults = document.getElementById("noResults");
  const count = document.getElementById("songCount");

  // Anfang: alles verstecken
  items.forEach((item) => {
    item.style.display = "none";
  });

  function updateCount(n) {
    count.textContent = n > 0 ? `${n} Song(s) gefunden` : "";
  }

  input.addEventListener("input", () => {
    const value = input.value.toLowerCase();
    let visibleCount = 0;

    items.forEach((item) => {
      const title = item.dataset.title ?? "";
      const match = title.includes(value);

      if (value === "") {
        item.style.display = "none";
      } else {
        item.style.display = match ? "block" : "none";
        if (match) visibleCount++;
      }
    });

    if (value === "") {
      noResults.style.display = "none";
      count.textContent = "";
      return;
    }

    updateCount(visibleCount);

    noResults.style.display = visibleCount === 0 ? "block" : "none";
  });
</script>